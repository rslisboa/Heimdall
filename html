const languageTutorState = {
  history: [],
  recognition: null,
  listening: false
};

const languageTutorNames = {
  'en-US': 'Ingles',
  'es-ES': 'Espanhol',
  'fr-FR': 'Frances',
  'ru-RU': 'Russo',
  'zh-CN': 'Chines',
  'ja-JP': 'Japones',
  'de-DE': 'Alemao',
  'pt-BR': 'Portugues'
};

function getLanguageTutorLang() {
  return document.getElementById('languageTutorSelect').value || 'en-US';
}

function appendLanguageTutorMessage(role, text) {
  const box = document.getElementById('languageTutorChat');

  if (!box) {
    return;
  }

  const msg = document.createElement('div');
  msg.className = `language-msg ${role}`;

  const label = document.createElement('div');
  label.className = 'language-msg-label';
  label.textContent = role === 'user' ? 'Voce' : 'Professor Heimdall';

  const body = document.createElement('div');
  body.textContent = text;

  msg.appendChild(label);
  msg.appendChild(body);
  box.appendChild(msg);
  box.scrollTop = box.scrollHeight;
}

function speakLanguageTutor(text) {
  if (!('speechSynthesis' in window) || !text) {
    return;
  }

  const lang = getLanguageTutorLang();
  const speakable = String(text)
    .replace(/^Correcao:.*$/gmi, '')
    .replace(/^Correção:.*$/gmi, '')
    .replace(/^Resposta:/gmi, '')
    .replace(/^Proxima pergunta:/gmi, '')
    .replace(/^Próxima pergunta:/gmi, '')
    .trim();

  if (!speakable) {
    return;
  }

  window.speechSynthesis.cancel();

  const utterance = new SpeechSynthesisUtterance(speakable);
  const voices = window.speechSynthesis.getVoices();
  utterance.lang = lang;
  utterance.voice =
    voices.find(voice => voice.lang === lang) ||
    voices.find(voice => voice.lang.toLowerCase().startsWith(lang.slice(0, 2).toLowerCase())) ||
    null;
  utterance.rate = lang === 'ja-JP' || lang === 'zh-CN' ? .88 : .94;
  utterance.pitch = 1;

  window.speechSynthesis.speak(utterance);
}

async function sendLanguageTutorMessage(textFromVoice = '') {
  const input = document.getElementById('languageTutorInput');
  const sendBtn = document.getElementById('languageTutorSendBtn');
  const status = document.getElementById('languageTutorStatus');
  const message = String(textFromVoice || input.value || '').trim();

  if (!message || !input || !sendBtn) {
    return;
  }

  const lang = getLanguageTutorLang();

  appendLanguageTutorMessage('user', message);
  languageTutorState.history.push({role: 'user', content: message});
  input.value = '';
  sendBtn.disabled = true;
  sendBtn.textContent = 'Pensando...';

  if (status) {
    status.textContent = `Professor de ${languageTutorNames[lang] || 'idiomas'} analisando sua fala...`;
  }

  try {
    const response = await fetch('/api/language-tutor/chat', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({
        language: lang,
        message,
        history: languageTutorState.history.slice(-10)
      })
    });

    const data = await response.json();
    const reply = data.reply || data.message || 'Nao consegui gerar resposta agora.';

    appendLanguageTutorMessage('teacher', reply);
    languageTutorState.history.push({role: 'assistant', content: reply});
    speakLanguageTutor(reply);

    if (status) {
      status.textContent = 'Conversa pronta. Continue respondendo no idioma escolhido.';
    }

  } catch (error) {
    console.error('Erro no professor de idiomas:', error);
    appendLanguageTutorMessage('teacher', 'Erro ao consultar o professor de idiomas local.');

    if (status) {
      status.textContent = 'Falha ao consultar a LLM local.';
    }

  } finally {
    sendBtn.disabled = false;
    sendBtn.textContent = 'Enviar';
    input.focus();
  }
}

function setupLanguageTutor() {
  const select = document.getElementById('languageTutorSelect');
  const speakBtn = document.getElementById('languageTutorSpeakBtn');
  const sendBtn = document.getElementById('languageTutorSendBtn');
  const input = document.getElementById('languageTutorInput');
  const status = document.getElementById('languageTutorStatus');

  if (sendBtn) {
    sendBtn.addEventListener('click', () => sendLanguageTutorMessage());
  }

  if (input) {
    input.addEventListener('keydown', event => {
      if (event.key === 'Enter') {
        event.preventDefault();
        sendLanguageTutorMessage();
      }
    });
  }

  if (select) {
    select.addEventListener('change', () => {
      languageTutorState.history = [];
      if (status) {
        status.textContent = `Idioma ativo: ${languageTutorNames[getLanguageTutorLang()]}. Comece uma conversa curta.`;
      }
    });
  }

  if (!SpeechRecognition || !speakBtn) {
    if (speakBtn) {
      speakBtn.disabled = true;
      speakBtn.textContent = 'Voz indisponivel';
    }
    return;
  }

  speakBtn.addEventListener('click', () => {
    if (languageTutorState.listening && languageTutorState.recognition) {
      languageTutorState.recognition.stop();
      return;
    }

    const recognition = new SpeechRecognition();
    languageTutorState.recognition = recognition;
    languageTutorState.listening = true;

    recognition.lang = getLanguageTutorLang();
    recognition.continuous = false;
    recognition.interimResults = false;
    recognition.maxAlternatives = 1;

    speakBtn.classList.add('listening');
    speakBtn.textContent = 'Ouvindo...';
    if (status) {
      status.textContent = `Ouvindo em ${languageTutorNames[getLanguageTutorLang()] || 'idioma selecionado'}...`;
    }

    recognition.onresult = event => {
      const text = event.results[0][0].transcript;
      sendLanguageTutorMessage(text);
    };

    recognition.onerror = event => {
      if (status) {
        status.textContent = `Erro no reconhecimento de voz: ${event.error}`;
      }
    };

    recognition.onend = () => {
      languageTutorState.listening = false;
      speakBtn.classList.remove('listening');
      speakBtn.textContent = 'Falar';
    };

    recognition.start();
  });
}


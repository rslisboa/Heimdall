async function renderTaskPanel() {
  const panel = document.getElementById('taskPanel');
  const list = document.getElementById('taskList');
  const badge = document.getElementById('taskCountBadge');

  if (!panel || !list || !badge) {
    return;
  }

  if (currentView !== 'task') {
    panel.classList.remove('visible');
    return;
  }

  panel.classList.add('visible');
  list.innerHTML = '<div class="empty-state">Carregando lembretes locais...</div>';

  try {
    const data = await fetch('/api/tasks').then(r => r.json());
    const tasks = Array.isArray(data.items) ? data.items : [];

    const openTasks = tasks.filter(task => {
      const status = String(task.status || 'open').toLowerCase();
      return !['done', 'closed', 'concluida', 'completed'].includes(status);
    });

    badge.textContent = `${openTasks.length} ABERTO(S)`;

    list.innerHTML = '';

    if (!tasks.length) {
      list.innerHTML = '<div class="empty-state">Nenhum lembrete criado ainda. Escreva um pedido acima para o Heimdall guardar.</div>';
      return;
    }

    tasks.forEach(task => {
      const note = document.createElement('article');
      note.className = 'sticky-note';

      const summaryLength = String(task.attachment_summary || task.reminder_text || task.title || '').length;

      if (summaryLength > 115) {
        note.classList.add('sticky-note-tall');
      }

      const status = String(task.status || 'open').toLowerCase();
      const done = ['done', 'closed', 'concluida', 'completed'].includes(status);

      if (done) {
        note.classList.add('done');
      }

      const deadline = task.deadline ? formatDateTime(task.deadline) : 'Sem prazo definido';
      const summary = task.attachment_summary
        ? `IA: ${task.attachment_summary}`
        : getTaskAttachmentText(task);

      note.innerHTML = `
        <div class="sticky-pin"></div>

        <div class="sticky-note-title">${escapeHtml(task.title || 'Lembrete sem título')}</div>

        <div class="sticky-note-meta">
          ${escapeHtml(getTaskTypeLabel(task))} · ${escapeHtml(getTaskStatusLabel(status))}
          <br>
          ${escapeHtml(deadline)}
        </div>

        <div class="sticky-note-summary">
          ${escapeHtml(summary).slice(0, 220)}
        </div>

        <div class="sticky-note-footer">
        <span class="sticky-pill">${escapeHtml(getTaskAttachmentText(task))}</span>

        <div class="sticky-actions">
          <button type="button" class="task-status-btn" data-task-id="${escapeHtml(task.id || '')}" data-next-status="${done ? 'open' : 'done'}">
            ${done ? 'Reabrir' : 'Concluir'}
          </button>

          <button type="button" class="task-delete-btn" data-task-id="${escapeHtml(task.id || '')}" data-task-title="${escapeHtml(task.title || '')}">
            Excluir
          </button>
        </div>
      </div>
      `;

      note.addEventListener('click', () => openTaskModal(task));

      const statusBtn = note.querySelector('.task-status-btn');

      if (statusBtn) {
        statusBtn.addEventListener('click', async event => {
          event.stopPropagation();

          await fetch(`/api/tasks/${encodeURIComponent(statusBtn.dataset.taskId || '')}`, {
            method: 'PATCH',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({status: statusBtn.dataset.nextStatus || 'done'})
          });

          await renderTaskPanel();
          await loadEvents();
          await loadKpis();
          await loadActivity();
        });
      }

      const deleteBtn = note.querySelector('.task-delete-btn');

    if (deleteBtn) {
      deleteBtn.addEventListener('click', async event => {
        event.stopPropagation();

        try {
          await deleteTaskById(
            deleteBtn.dataset.taskId || '',
            deleteBtn.dataset.taskTitle || ''
          );
        } catch (error) {
          console.error('Erro ao excluir lembrete:', error);
          alert(`Não foi possível excluir o lembrete: ${error.message}`);
        }
      });
    }

      list.appendChild(note);
    });

  } catch (error) {
    console.error('Erro ao carregar tarefas:', error);
    list.innerHTML = '<div class="empty-state">Falha ao carregar lembretes locais.</div>';
  }
}


function startCommandCenterBootCore() {
  const canvas = document.getElementById('commandBootCanvas');

  if (!canvas) {
    return;
  }

  const ctx = canvas.getContext('2d');
  let W = 0;
  let H = 0;
  let cx = 0;
  let cy = 0;
  let t = 0;
  let orbs = [];
  let rings = [];
  let ringAngles = [];

  function resize() {
    const rect = canvas.getBoundingClientRect();
    W = Math.max(260, Math.floor(rect.width));
    H = Math.max(260, Math.floor(rect.height));

    canvas.width = W;
    canvas.height = H;

    cx = W / 2;
    cy = H / 2;

    initParticles();
  }

  function initParticles() {
    const rs = Math.min(W, H);

    orbs = [];
    for (let i = 0; i < 34; i++) {
      const angle = (i / 34) * Math.PI * 2;
      const rScale = rs * 0.34;

      orbs.push({
        baseAngle: angle,
        r: rScale + Math.random() * rScale * 0.18,
        speed: (Math.random() > 0.5 ? 1 : -1) * (0.004 + Math.random() * 0.011),
        size: Math.max(2, rs * 0.006) + Math.random() * Math.max(1, rs * 0.004),
        color: ['#00ff88', '#00ccff', '#7b5fff', '#4da8f7', '#8cffc3', '#ffffff'][Math.floor(Math.random() * 6)],
        offset: Math.random() * Math.PI * 2
      });
    }

    rings = [
      { r: rs * 0.22, speed: 0.008, color: '#8cffc3', dash: [6, 8], w: 1.0, op: 0.66 },
      { r: rs * 0.31, speed: -0.005, color: '#7b5fff', dash: [12, 6], w: 1.1, op: 0.46 },
      { r: rs * 0.40, speed: 0.003, color: '#00ccff', dash: [4, 14], w: 0.9, op: 0.38 },
      { r: rs * 0.48, speed: -0.007, color: '#4da8f7', dash: [8, 10], w: 0.8, op: 0.32 }
    ];

    ringAngles = rings.map(() => 0);
  }

  function drawGrid() {
    ctx.strokeStyle = '#00ff88';
    ctx.lineWidth = 0.3;
    ctx.globalAlpha = 0.055;

    for (let x = 0; x < W; x += 24) {
      ctx.beginPath();
      ctx.moveTo(x, 0);
      ctx.lineTo(x, H);
      ctx.stroke();
    }

    for (let y = 0; y < H; y += 24) {
      ctx.beginPath();
      ctx.moveTo(0, y);
      ctx.lineTo(W, y);
      ctx.stroke();
    }

    ctx.globalAlpha = 1;
  }

  function drawRings() {
    rings.forEach((rg, i) => {
      ringAngles[i] += rg.speed;

      ctx.save();
      ctx.translate(cx, cy);
      ctx.rotate(ringAngles[i]);
      ctx.setLineDash(rg.dash);
      ctx.strokeStyle = rg.color;
      ctx.globalAlpha = rg.op;
      ctx.lineWidth = rg.w;
      ctx.beginPath();
      ctx.arc(0, 0, rg.r, 0, Math.PI * 2);
      ctx.stroke();
      ctx.restore();
    });

    ctx.setLineDash([]);
    ctx.globalAlpha = 1;
  }

  function drawOrbs() {
    orbs.forEach(o => {
      const ang = o.baseAngle + t * o.speed;
      const wobble = Math.sin(t * 0.02 + o.offset) * 8;

      const ox = cx + Math.cos(ang) * (o.r + wobble);
      const oy = cy + Math.sin(ang) * (o.r + wobble) * 0.55;

      ctx.fillStyle = o.color;
      ctx.globalAlpha = 0.48 + 0.35 * Math.abs(Math.sin(t * 0.03 + o.offset));
      ctx.beginPath();
      ctx.arc(ox, oy, o.size, 0, Math.PI * 2);
      ctx.fill();
    });

    ctx.globalAlpha = 1;
  }

  function drawCore() {
    const pulse = 0.90 + 0.10 * Math.sin(t * 0.055);
    const coreR = Math.min(W, H) * 0.16 * pulse;
    const spinnerR = coreR + 52;

    const grd = ctx.createRadialGradient(cx, cy, 0, cx, cy, coreR);
    grd.addColorStop(0, 'rgba(255,255,255,0.88)');
    grd.addColorStop(0.22, 'rgba(140,255,195,0.80)');
    grd.addColorStop(0.52, 'rgba(77,168,247,0.62)');
    grd.addColorStop(0.78, 'rgba(15,80,130,0.38)');
    grd.addColorStop(1, 'rgba(0,0,0,0)');

    ctx.fillStyle = grd;
    ctx.beginPath();
    ctx.arc(cx, cy, coreR, 0, Math.PI * 2);
    ctx.fill();

    ctx.strokeStyle = 'rgba(77,168,247,.18)';
    ctx.lineWidth = 7;
    ctx.beginPath();
    ctx.arc(cx, cy, spinnerR, 0, Math.PI * 2);
    ctx.stroke();

    ctx.strokeStyle = '#4da8f7';
    ctx.lineWidth = 7;
    ctx.lineCap = 'round';
    ctx.shadowColor = '#4da8f7';
    ctx.shadowBlur = 18;
    ctx.beginPath();
    ctx.arc(cx, cy, spinnerR, -Math.PI / 2, -Math.PI / 2 + Math.PI * 2);
    ctx.stroke();
    ctx.shadowBlur = 0;
  }

  function frame() {
    t += 1;

    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = 'rgba(0,0,8,.12)';
    ctx.fillRect(0, 0, W, H);

    drawGrid();
    drawRings();
    drawOrbs();
    drawCore();

    requestAnimationFrame(frame);
  }

  resize();
  window.addEventListener('resize', resize);
  requestAnimationFrame(frame);
}

function drawCommandCenterLinks() {
  const stage = document.querySelector('.brain-stage');
  const svg = document.getElementById('commandLinkLines');
  const core = document.querySelector('.command-boot-button');
  const nodes = Array.from(document.querySelectorAll('.brain-stage .agent-node'));

  if (!stage || !svg || !core || !nodes.length) {
    return;
  }

  const stageRect = stage.getBoundingClientRect();
  const coreRect = core.getBoundingClientRect();

  if (!stageRect.width || !stageRect.height) {
    return;
  }

  const coreX = coreRect.left + coreRect.width / 2 - stageRect.left;
  const coreY = coreRect.top + coreRect.height / 2 - stageRect.top;

  svg.setAttribute('viewBox', `0 0 ${stageRect.width} ${stageRect.height}`);
  svg.innerHTML = '';

  nodes.forEach((node, index) => {
    const nodeRect = node.getBoundingClientRect();

    const nodeX = nodeRect.left + nodeRect.width / 2 - stageRect.left;
    const nodeY = nodeRect.top + nodeRect.height / 2 - stageRect.top;

    const baseLine = document.createElementNS('http://www.w3.org/2000/svg', 'line');
    baseLine.classList.add('command-link-base');
    baseLine.setAttribute('x1', coreX);
    baseLine.setAttribute('y1', coreY);
    baseLine.setAttribute('x2', nodeX);
    baseLine.setAttribute('y2', nodeY);

    const flowLine = document.createElementNS('http://www.w3.org/2000/svg', 'line');
    flowLine.classList.add('command-link-flow');
    flowLine.setAttribute('x1', coreX);
    flowLine.setAttribute('y1', coreY);
    flowLine.setAttribute('x2', nodeX);
    flowLine.setAttribute('y2', nodeY);
    flowLine.style.animationDelay = `${index * 110}ms`;

    const dot = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    dot.classList.add('command-link-dot');
    dot.setAttribute('cx', nodeX);
    dot.setAttribute('cy', nodeY);
    dot.setAttribute('r', '2.8');

    svg.appendChild(baseLine);
    svg.appendChild(flowLine);
    svg.appendChild(dot);
  });
}


async function loadEvents() {
  const eventsRaw = await fetch('/api/events?limit=5000').then(r => r.json());
  const events = deduplicarEventosCalendario(eventsRaw);
  const cfg = viewConfig[currentView] || viewConfig.all;

  let filteredEvents = cfg.source
    ? events.filter(e => e.source === cfg.source)
    : events;

  renderCalendarPanel(events);
  renderEmailExecutivePanel();
  await renderTaskPanel();
  renderLanguageTutorPanel();

  if (currentView === 'email' && emailSearchTerm.trim()) {
    const term = emailSearchTerm.trim().toLowerCase();
    filteredEvents = filteredEvents.filter(e => {
      const metadata = e.metadata || {};
      return [
        e.title,
        e.detail,
        metadata.sender,
        metadata.from,
        metadata.subject,
        metadata.snippet
      ].some(value => String(value || '').toLowerCase().includes(term));
    });
  }

  if (currentView === 'calendar') {
    filteredEvents = filteredEvents.filter(e => {
      return getCalendarEventDateKey(e) === selectedCalendarDate;
    });

    document.getElementById('eventsTitle').textContent =
      `Reuniões de ${getCalendarSelectedDateTitle()}`;

    document.getElementById('eventsBadge').textContent =
      `${filteredEvents.length} REUNIÃO(ÕES)`;
  } else {
    document.getElementById('eventsTitle').textContent = cfg.title;
    document.getElementById('eventsBadge').textContent = cfg.badge;
  }

  renderGroupedEvents(filteredEvents);

  if (currentView === 'email') {
    loadEmailExecutive();
  }
}


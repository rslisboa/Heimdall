<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <title>{{ title }} — Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
  :root {
    --bg:#0c0e15;
    --panel:#0f1220;
    --panel2:#0d0f18;
    --line:#1c2236;
    --line2:#1a2030;
    --text:#dde3f0;
    --title:#c8d2e8;
    --muted:#8b9cc0;
    --muted2:#3d4a6a;

    --blue:#4da8f7;
    --green:#2dd4a0;
    --green-dark:#0d3b2e;
    --green-light:#8cffc3;
    --amber:#f0a930;
    --red:#f06060;
    --purple:#9d7eff;
    --brand:#9d7eff;
    --lime:#B5FF20;
  }

  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.35} }
  @keyframes slideIn { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:translateY(0)} }
  @keyframes ticker {
    0% {
      transform: translateX(100vw);
    }

    100% {
      transform: translateX(-100%);
    }
  }

  * { box-sizing:border-box; }

  body {
    margin:0;
    background:var(--bg);
    color:var(--text);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
  }

  .root { min-height:100vh; display:flex; flex-direction:column; }

  .ticker-wrap {
    height:30px;
    overflow:hidden;
    border-bottom:1px solid var(--line);
    background:#0a0c13;
    display:flex;
    align-items:center;
  }

  .ticker {
    display:flex;
    gap:32px;
    white-space:nowrap;
    animation:ticker 20s linear infinite;
    font-size:13px;
    font-weight:800;
    color:#9fb0d0;
    letter-spacing:.4px;
  }

  .ticker-wrap:hover .ticker {
    animation-play-state: paused;
  }

  body.theme-light {
    --bg:#f5f8fb;
    --panel:#ffffff;
    --panel2:#eef3f8;
    --line:#d7e1ec;
    --line2:#c9d6e5;
    --text:#152033;
    --title:#1d2b42;
    --muted:#4e6078;
    --muted2:#74849a;
    background:#f5f8fb;
  }

.ticker span strong {
  color: #8cffc3;
  font-size: 15px;
  font-weight: 900;
}

  .topbar {
    height:44px;
    background:#0f1220;
    border-bottom:1px solid var(--line);
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding:0 18px;
  }

  .logo {
    letter-spacing:2px;
    color:var(--brand);
    font-weight:700;
    font-size:14px;
  }

  .top-right {
    display:flex;
    gap:14px;
    align-items:center;
    font-size:11px;
    color:var(--muted2);
  }

  .dot {
    width:7px;
    height:7px;
    border-radius:50%;
    background:var(--green);
    animation:pulse 2s infinite;
    display:inline-block;
    margin-right:6px;
  }

  .layout {
    flex:1;
    display:grid;
    grid-template-columns:220px minmax(0,1fr) 290px;
    gap:1px;
    background:var(--line);
    min-height:calc(100vh - 74px);
  }

  aside, main, .right { background:var(--bg); }

  aside {
    padding:14px 8px;
    display:flex;
    flex-direction:column;
    gap:5px;
  }

  .side-label {
    font-size:10px;
    letter-spacing:1.5px;
    color:#263150;
    padding:4px 10px;
    margin-bottom:4px;
    font-weight:700;
  }

  .nav {
    padding:10px;
    border-radius:7px;
    color:var(--muted2);
    font-size:12px;
    display:flex;
    gap:8px;
    align-items:center;
    cursor:pointer;
    transition:all .15s;
  }

  .nav:hover {
    background:#141828;
    color:var(--muted);
  }

  .nav.offline {
    color:#596578;
    cursor:not-allowed;
    opacity:.68;
  }

  .nav.offline:hover {
    background:transparent;
    color:#596578;
  }

  .nav.active {
    background:#141828;
    color:var(--purple);
    border-left:2px solid var(--brand);
    padding-left:8px;
  }

  main {
    background:var(--panel2);
    padding:16px;
    overflow:auto;
  }

  .kpis {
    display:grid;
    grid-template-columns:repeat(3, minmax(110px,1fr));
    gap:10px;
    margin-bottom:12px;
  }

  .kpi {
    background:var(--panel);
    border:1px solid var(--line);
    border-radius:8px;
    padding:12px 10px;
    text-align:center;
    animation:slideIn .35s ease both;
  }

  .kpi:nth-child(1){ border-top:2px solid var(--blue); }
  .kpi:nth-child(2){ border-top:2px solid var(--green); }
  .kpi:nth-child(3){ border-top:2px solid var(--amber); }
  .kpi:nth-child(4){ border-top:2px solid var(--red); }
  .kpi:nth-child(5){ border-top:2px solid var(--purple); }
  .kpi:nth-child(6){ border-top:2px solid var(--green); }

  .kpi .val {
    font-size:25px;
    font-weight:800;
    line-height:1;
  }

  .kpi .lbl {
    color:var(--title);
    font-size:11px;
    margin-top:6px;
    letter-spacing:.6px;
    font-weight:700;
  }

  .kpi-sub {
  color: #8b9cc0;
  font-size: 11px;
  margin-top: 5px;
  letter-spacing: .6px;
  font-weight: 800;
}

  .blue{color:var(--blue)}
  .green{color:var(--green)}
  .amber{color:var(--amber)}
  .red{color:var(--red)}
  .purple{color:var(--purple)}

  .panel {
    background:var(--panel);
    border:1px solid var(--line);
    border-radius:10px;
    padding:13px;
    margin-bottom:12px;
  }

  .panel-header {
    display:flex;
    align-items:center;
    justify-content:space-between;
    margin-bottom:10px;
  }

  .panel-title {
    color:var(--title);
    font-size:13px;
    text-transform:uppercase;
    letter-spacing:1.4px;
    font-weight:800;
  }

.badge {
  font-size:10px;
  padding:3px 9px;
  border-radius:999px;
  font-weight:700;
}

  .badge.live { background:#0b2a20; color:var(--green); animation:pulse 2s infinite; }
  .badge.warn { background:#2a1900; color:var(--amber); }
  .badge.info { background:#081428; color:var(--blue); }

  .events { display:flex; flex-direction:column; gap:7px; }

  .event {
    background:var(--bg);
    border:1px solid var(--line2);
    border-radius:8px;
    padding:10px;
    display:grid;
    grid-template-columns:9px 1fr auto;
    gap:10px;
    align-items:start;
    animation:slideIn .25s ease both;
  }

  .event:hover { border-color:var(--brand); }

  .event-dot {
    width:9px;
    height:9px;
    border-radius:50%;
    margin-top:4px;
  }

  .event-title {
    font-size:13px;
    color:var(--title);
    font-weight:700;
  }

  .event-detail {
    font-size:11px;
    color:var(--muted);
    margin-top:4px;
    line-height:1.45;
  }

  .score {
    font-size:10px;
    border-radius:999px;
    padding:3px 7px;
    font-weight:700;
  }

  .score-high { background:#3b0a0a; color:var(--red); }
  .score-mid { background:#2d1f00; color:var(--amber); }
  .score-low { background:#0a1a2e; color:var(--blue); }

  .right {
    padding:14px;
    display:flex;
    flex-direction:column;
    gap:12px;
    overflow:auto;
  }

  .agent-box, .log-box, .voice-box {
    background:var(--panel);
    border:1px solid var(--line);
    border-radius:10px;
    padding:12px;
  }

  .agent-row {
    display:grid;
    grid-template-columns:32px 1fr auto;
    gap:9px;
    align-items:center;
    margin-bottom:10px;
  }

  .agent-icon {
    width:32px;
    height:32px;
    border-radius:8px;
    display:flex;
    align-items:center;
    justify-content:center;
    background:#111827;
  }

  .agent-name {
    font-size:13px;
    color:var(--title);
    font-weight:700;
  }

  .progress {
    height:4px;
    background:var(--line);
    border-radius:999px;
    overflow:hidden;
    margin-top:4px;
  }

  .fill {
    height:100%;
    border-radius:999px;
    transition:width .4s ease;
  }

  .log-lines {
    height:260px;
    overflow:auto;
    padding-right:4px;
  }

  .log-line {
    color:var(--muted);
    font-size:11px;
    line-height:1.8;
    border-bottom:1px solid rgba(28,34,54,.35);
    padding:2px 0;
  }

  .log-line .ts { color:#334155; }
  .log-line .lvl-info { color:var(--blue); }
  .log-line .lvl-error { color:var(--red); }
  .log-line .lvl-warn { color:var(--amber); }

  .voice-button {
    width:100%;
    border:1px solid var(--brand);
    background:#15112a;
    color:var(--purple);
    border-radius:9px;
    padding:10px;
    cursor:pointer;
    font-weight:800;
    letter-spacing:.5px;
  }

  .voice-button.listening {
    background:#2a0f17;
    border-color:var(--red);
    color:var(--red);
    animation:pulse 1s infinite;
  }

  .voice-text {
    color:var(--title);
    font-size:12px;
    line-height:1.55;
    margin-top:8px;
  }

  .voice-speaking-box {
  display: none;
  background: var(--panel);
  border: 1px solid rgba(77, 168, 247, .45);
  border-radius: 10px;
  padding: 12px;
  box-shadow: 0 0 18px rgba(77, 168, 247, .10);
}

.voice-speaking-box.active {
  display: block;
}

.voice-speaking-title {
  color: #4da8f7;
  font-size: 11px;
  font-weight: 900;
  letter-spacing: 1.2px;
  margin-bottom: 10px;
}

.voice-wave {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5px;
  margin-bottom: 9px;
}

.voice-wave span {
  width: 5px;
  height: 12px;
  border-radius: 999px;
  background: #4da8f7;
  box-shadow: 0 0 10px rgba(77, 168, 247, .55);
  animation: heimdallSpeaking 820ms ease-in-out infinite;
}

.voice-wave span:nth-child(1) { animation-delay: 0ms; }
.voice-wave span:nth-child(2) { animation-delay: 90ms; }
.voice-wave span:nth-child(3) { animation-delay: 180ms; }
.voice-wave span:nth-child(4) { animation-delay: 270ms; }
.voice-wave span:nth-child(5) { animation-delay: 180ms; }
.voice-wave span:nth-child(6) { animation-delay: 90ms; }
.voice-wave span:nth-child(7) { animation-delay: 0ms; }

.voice-speaking-text {
  color: #9fb0d0;
  font-size: 11px;
  line-height: 1.45;
  text-align: center;
  font-weight: 700;
}

@keyframes heimdallSpeaking {
  0%, 100% {
    height: 10px;
    opacity: .45;
  }

  50% {
    height: 38px;
    opacity: 1;
  }
}

  @media(max-width:1100px) {
    .layout { grid-template-columns:1fr; }
    aside { display:none; }
    .kpis { grid-template-columns:repeat(2,1fr); }
  }

  /* =========================================================
   AJUSTE DE LEGIBILIDADE — MENU LATERAL + TICKER TOPO
   ========================================================= */

/* Animação / ticker do topo */
.ticker-wrap {
  height: 42px;
  background: #0a0c13;
  border-bottom: 1px solid #27314a;
}

.ticker {
  font-size: 12px;
  font-weight: 700;
  color: #9fb0d0;
  letter-spacing: .4px;
}

.ticker span {
  color: #9fb0d0;
}

.ticker {
  font-size: 15px;
  font-weight: 800;
  color: #9fb0d0;
  letter-spacing: .5px;
}

/* Topbar */
.top-right {
  font-size: 12px;
  color: #9fb0d0;
  font-weight: 700;
}

.logo {
  font-size: 15px;
}

/* Títulos pequenos da sidebar */
.side-label {
  font-size: 13px;
  color: #7f8fb2;
  font-weight: 900;
  letter-spacing: 1.6px;
}

/* Menu lateral */
.nav {
  font-size: 15px;
  color: #9fb0d0;
  font-weight: 800;
  padding: 13px 11px;
}

.nav:hover {
  background: #141828;
  color: #dde3f0;
}

.nav.active {
  color: #c7b8ff;
  background: #171b2d;
  border-left: 3px solid #9d7eff;
}

/* Texto da memória local/sidebar inferior */
aside .side-label,
.mem-lbl {
  color: #7f8fb2;
  font-size: 11px;
  font-weight: 800;
}

aside div[style*="SQLite ativo"],
.mem-val {
  color: #9fb0d0 !important;
  font-size: 11px !important;
  font-weight: 700;
}

/* Títulos dos painéis */
.panel-title {
  font-size: 14px;
  color: #d8e1f5;
  font-weight: 900;
}

/* Labels dos cards */
.kpi .lbl {
  font-size: 12px;
  color: #c8d2e8;
  font-weight: 800;
}

/* Textos internos dos eventos */
.event-title {
  font-size: 14px;
  color: #e5ecfb;
  font-weight: 800;
}

.event-detail {
  font-size: 12px;
  color: #a7b5d4;
}

/* Lado direito */
.agent-name {
  font-size: 13px;
  color: #e5ecfb;
  font-weight: 800;
}

.voice-text {
  font-size: 12px;
  color: #c8d2e8;
  font-weight: 600;
}

.log-line {
  font-size: 11px;
  color: #a7b5d4;
}

/* =========================================================
   AGRUPAMENTO POR DATA — EVENTOS
   ========================================================= */

.date-group {
  border: 1px solid #1c2236;
  border-radius: 10px;
  overflow: hidden;
  background: #0c0e15;
  margin-bottom: 10px;
}

.date-group-header {
  width: 100%;
  border: 0;
  background: #111626;
  color: #d8e1f5;
  padding: 10px 12px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-family: inherit;
  font-size: 13px;
  font-weight: 900;
  letter-spacing: .8px;
  text-transform: uppercase;
}

.date-group-header:hover {
  background: #151b2f;
}

.date-group-left {
  display: flex;
  align-items: center;
  gap: 8px;
}

.date-caret {
  color: #8cffc3;
  font-size: 13px;
}

.date-count {
  color: #8cffc3;
  font-size: 11px;
  font-weight: 900;
}

.date-group-items {
  display: flex;
  flex-direction: column;
  gap: 7px;
  padding: 8px;
}

.date-group.collapsed .date-group-items {
  display: none;
}

.date-group.collapsed .date-caret {
  transform: rotate(-90deg);
}

/* =========================================================
   CORREÇÃO FINAL DO TICKER — COMEÇA FORA DA TELA À DIREITA
   ========================================================= */

.ticker-wrap {
  justify-content: flex-start;
  overflow: hidden;
}

.ticker {
  width: max-content;
  flex-shrink: 0;
  will-change: transform;
  animation-name: ticker;
  animation-duration: 22s;
  animation-timing-function: linear;
  animation-iteration-count: infinite;
}

.empty-state {
  border: 1px dashed #27314a;
  border-radius: 10px;
  padding: 18px;
  color: #9fb0d0;
  text-align: center;
  font-size: 13px;
  font-weight: 700;
  background: #0c0e15;
}

.activity-live-badge {
  font-size: 12px;
  padding: 5px 12px;
  font-weight: 900;
  letter-spacing: .6px;
}

.event {
  cursor: pointer;
}

.event-extra {
  grid-column: 2 / 4;
  display: none;
  border-top: 1px solid #1c2236;
  margin-top: 8px;
  padding-top: 9px;
  color: #a7b5d4;
  font-size: 12px;
  line-height: 1.55;
}

.event.open .event-extra {
  display: block;
}

.event-extra-title {
  color: #8cffc3;
  font-size: 11px;
  font-weight: 900;
  letter-spacing: .8px;
  text-transform: uppercase;
  margin-bottom: 6px;
}

.event-extra-grid {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: 6px 10px;
}

.event-extra-label {
  color: #7f8fb2;
  font-weight: 800;
}

.event-extra-value {
  color: #d8e1f5;
  word-break: break-word;
}

/* =========================================================
   CALENDÁRIO DINÂMICO — REUNIÕES
   ========================================================= */

.calendar-panel {
  animation: slideIn .25s ease both;
}

.calendar-toolbar {
  display: grid;
  grid-template-columns: 38px 1fr 38px;
  gap: 8px;
  align-items: center;
  margin-bottom: 10px;
}

.calendar-nav-btn {
  height: 34px;
  border: 1px solid #27314a;
  background: #0c0e15;
  color: #4da8f7;
  border-radius: 8px;
  cursor: pointer;
  font-size: 22px;
  font-weight: 900;
  font-family: inherit;
}

.calendar-nav-btn:hover {
  border-color: #4da8f7;
  box-shadow: 0 0 14px rgba(77, 168, 247, .18);
}

.calendar-month-title {
  color: #d8e1f5;
  text-align: center;
  font-size: 13px;
  font-weight: 900;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 6px;
  margin-bottom: 6px;
}

.calendar-weekdays span {
  color: #7f8fb2;
  font-size: 10px;
  font-weight: 900;
  text-align: center;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 6px;
}

.calendar-day {
  min-height: 48px;
  border: 1px solid #1c2236;
  background: #0c0e15;
  color: #9fb0d0;
  border-radius: 9px;
  cursor: pointer;
  padding: 7px 6px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  font-family: inherit;
  transition: all .15s ease;
}

.calendar-day:hover {
  border-color: #4da8f7;
  background: #101827;
}

.calendar-day.empty {
  opacity: .22;
  cursor: default;
}

.calendar-day.selected {
  border-color: #4da8f7;
  background: #081428;
  box-shadow: 0 0 18px rgba(77, 168, 247, .16);
}

.calendar-day.today {
  border-color: #8cffc3;
}

.calendar-day-number {
  font-size: 13px;
  font-weight: 900;
  color: #d8e1f5;
}

.calendar-day-count {
  font-size: 10px;
  font-weight: 900;
  color: #4da8f7;
}

.calendar-day.has-meeting .calendar-day-count {
  color: #8cffc3;
}

/* =========================================================
   TELA DE ABERTURA — HEIMDALL PORTAL
   ========================================================= */

.heimdall-boot {
  position: fixed;
  inset: 0;
  z-index: 999999;
  background: #000008;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity .65s ease, visibility .65s ease;
}

.heimdall-boot.done {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}

.heimdall-boot.ready {
  cursor: pointer;
}

.heimdall-boot.ready .heimdall-boot-ui {
  opacity: 0;
  visibility: hidden;
  transform: translateY(18px);
  pointer-events: none;
}

#heimdallBootCanvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  display: block;
  background: #000008;
}

.heimdall-boot-ui {
  position: relative;
  z-index: 2;
  margin-top: min(58vh, 470px);
  width: min(600px, calc(100vw - 36px));
  text-align: center;
  padding: 18px 20px;
  border: 1px solid rgba(77, 168, 247, .24);
  border-radius: 14px;
  background: rgba(8, 12, 24, .55);
  box-shadow: 0 0 30px rgba(77, 168, 247, .12);
  backdrop-filter: blur(6px);
  transition: opacity .45s ease, visibility .45s ease, transform .45s ease;
}

.heimdall-boot-kicker {
  color: #8cffc3;
  font-size: 11px;
  font-weight: 900;
  letter-spacing: 2px;
  margin-bottom: 7px;
}

.heimdall-boot-title {
  color: #d8e1f5;
  font-size: clamp(18px, 3vw, 30px);
  font-weight: 900;
  letter-spacing: 2px;
  text-shadow: 0 0 22px rgba(77, 168, 247, .35);
}

.heimdall-boot-subtitle {
  color: #9fb0d0;
  font-size: 12px;
  font-weight: 700;
  line-height: 1.45;
  margin-top: 8px;
}

.heimdall-boot-progress {
  height: 5px;
  width: 100%;
  background: rgba(28, 34, 54, .95);
  border-radius: 999px;
  overflow: hidden;
  margin-top: 14px;
}

#heimdallBootProgressFill {
  height: 100%;
  width: 0%;
  border-radius: 999px;
  background: linear-gradient(90deg, #4da8f7, #8cffc3);
  box-shadow: 0 0 18px rgba(77, 168, 247, .75);
}

.heimdall-boot-status {
  color: #4da8f7;
  font-size: 10px;
  font-weight: 900;
  letter-spacing: 1.4px;
  margin-top: 9px;
}

/* =========================================================
   CHAT - IA
   ========================================================= */

.chat-ia-page {
  height: calc(100vh - 108px);
  display: flex;
  flex-direction: column;
  background:
    radial-gradient(circle at top left, rgba(140,255,195,.08), transparent 32%),
    radial-gradient(circle at bottom right, rgba(77,168,247,.08), transparent 34%),
    #0c0e15;
  border: 1px solid #1c2236;
  border-radius: 14px;
  overflow: hidden;
}

.chat-ia-header {
  padding: 18px 20px;
  border-bottom: 1px solid #1c2236;
  background: rgba(15, 18, 32, .92);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.chat-ia-kicker {
  color: #8cffc3;
  font-size: 10px;
  font-weight: 900;
  letter-spacing: 1.8px;
  margin-bottom: 5px;
}

.chat-ia-header h2 {
  margin: 0;
  color: #d8e1f5;
  font-size: 22px;
  font-weight: 900;
  letter-spacing: .8px;
}

.chat-ia-header p {
  margin: 6px 0 0;
  color: #8b9cc0;
  font-size: 12px;
  font-weight: 700;
}

.chat-ia-status {
  font-size: 10px;
  padding: 5px 11px;
  border-radius: 999px;
  font-weight: 900;
  letter-spacing: .8px;
  background: #081428;
  color: #4da8f7;
}

.chat-ia-status.ok {
  background: #0b2a20;
  color: #8cffc3;
}

.chat-ia-status.error {
  background: #3b0a0a;
  color: #f06060;
}

.chat-ia-messages {
  flex: 1;
  overflow: auto;
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.chat-message {
  display: flex;
  gap: 10px;
  align-items: flex-start;
  max-width: 86%;
}

.chat-message.user {
  align-self: flex-end;
  flex-direction: row-reverse;
}

.chat-message.assistant {
  align-self: flex-start;
}

.chat-avatar {
  width: 39px;
  height: 39px;
  border-radius: 10px;
  background: #111827;
  border: 1px solid #27314a;
  color: #8cffc3;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 900;
  flex-shrink: 0;
}

.chat-message.user .chat-avatar {
  color: #4da8f7;
}

.chat-bubble {
  background: #0f1220;
  border: 1px solid #1c2236;
  color: #dde3f0;
  padding: 12px 14px;
  border-radius: 14px;
  font-size: 15px;
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-word;
}

.chat-message.user .chat-bubble {
  background: #081428;
  border-color: rgba(77,168,247,.35);
}

.chat-message.assistant .chat-bubble {
  background: #0d1516;
  border-color: rgba(140,255,195,.22);
}

.chat-ia-attachments {
  display: none;
  gap: 8px;
  padding: 10px 16px;
  border-top: 1px solid #1c2236;
  background: rgba(15,18,32,.7);
  overflow-x: auto;
}

.chat-ia-attachments.active {
  display: flex;
}

.chat-attachment-chip {
  display: flex;
  align-items: center;
  gap: 8px;
  background: #0c0e15;
  border: 1px solid #27314a;
  color: #c8d2e8;
  border-radius: 999px;
  padding: 6px 10px;
  font-size: 11px;
  font-weight: 800;
  white-space: nowrap;
}

.chat-attachment-chip button {
  border: 0;
  background: transparent;
  color: #f06060;
  cursor: pointer;
  font-weight: 900;
}

.chat-ia-composer {
  display: grid;
  grid-template-columns: 42px 1fr auto;
  gap: 10px;
  padding: 14px;
  border-top: 1px solid #1c2236;
  background: rgba(15, 18, 32, .95);
}

.chat-ia-input {
  max-height: 160px;
  resize: none;
  border-radius: 12px;
  border: 1px solid #27314a;
  background: #0c0e15;
  color: #dde3f0;
  padding: 12px 14px;
  font-family: inherit;
  font-size: 15px;
  line-height: 1.6;
  outline: none;
}

.chat-ia-input:focus {
  border-color: #8cffc3;
  box-shadow: 0 0 0 2px rgba(140,255,195,.08);
}

.chat-ia-attach,
.chat-ia-send {
  border-radius: 12px;
  border: 1px solid #27314a;
  background: #111827;
  color: #dde3f0;
  cursor: pointer;
  font-family: inherit;
  font-weight: 900;
}

.chat-ia-attach {
  font-size: 20px;
}

.chat-ia-send {
  padding: 0 18px;
  border-color: #8cffc3;
  background: #0d3b2e;
  color: #8cffc3;
}

.chat-ia-send:disabled {
  opacity: .55;
  cursor: not-allowed;
}

/* =========================================================
   HEIMDALL COMMAND CENTER - INTERFACE INTERNA
   ========================================================= */

.layout {
  grid-template-columns: minmax(0, 1fr) 318px;
}

.layout > aside {
  display: none;
}

main {
  padding: 18px;
}

.command-center {

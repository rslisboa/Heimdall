function formatNewsDate(value) {
  if (!value) {
    return 'Data nao informada';
  }

  const parsed = new Date(value);

  if (Number.isNaN(parsed.getTime())) {
    return value;
  }

  return parsed.toLocaleString('pt-BR', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });
}

async function loadAiNews(force = false) {
  const grid = document.getElementById('newsGrid');

  if (!grid) {
    return;
  }

  grid.innerHTML = '<div class="empty-state">Buscando fontes confiaveis...</div>';
  grid.className = 'news-sections';

  try {
    const data = force
      ? await preloadAiNews(true)
      : (aiNewsCache || await preloadAiNews(false));
    const payload = data || {};
    const fallbackItems = Array.isArray(payload.items) ? payload.items : [];
    const sections = payload.sections && typeof payload.sections === 'object'
      ? payload.sections
      : {
          news: {
            title: 'Noticias de IA',
            subtitle: 'Portais confiaveis e variados, com classificacao da IA local.',
            items: fallbackItems
          }
        };
    const sectionOrder = ['news', 'podcasts', 'videos', 'papers'];

    grid.innerHTML = '';

    const visibleSections = sectionOrder
      .map(key => ({ key, ...(sections[key] || {}) }))
      .map(section => {
        const term = newsSearchTerm.trim().toLowerCase();
        const items = Array.isArray(section.items) ? section.items : [];

        if (!term) {
          return { ...section, items };
        }

        return {
          ...section,
          items: items.filter(item => [
            item.title,
            item.source,
            item.detail,
            item.summary,
            item.authors,
            item.sentiment
          ].some(value => String(value || '').toLowerCase().includes(term)))
        };
      })
      .filter(section => section.items.length);

    if (!visibleSections.length) {
      grid.innerHTML = '<div class="empty-state">Nenhum conteudo de IA encontrado para este filtro.</div>';
      return;
    }

    const linkLabelByType = {
      news: 'Abrir noticia verificada',
      podcast: 'Ouvir episodio',
      video: 'Assistir no YouTube',
      paper: 'Abrir paper'
    };

    const renderCard = (item) => {
      const card = document.createElement('article');
      card.className = 'news-card';
      const stars = Math.max(1, Math.min(5, Number(item.stars || 3)));
      const type = item.type || 'news';
      const detail = item.detail ? `<div class="news-card-detail">${escapeHtml(String(item.detail).slice(0, 260))}</div>` : '';
      const authors = item.authors ? `<br>Autores: ${escapeHtml(item.authors)}` : '';
      const pdfLink = item.pdf_url
        ? `<a href="${escapeHtml(item.pdf_url)}" target="_blank" rel="noopener noreferrer">PDF tecnico</a>`
        : '';
      card.innerHTML = `
        <div class="news-card-source">${escapeHtml(item.source || 'Fonte confiavel')}</div>
        <div class="stars">${'★'.repeat(stars)}${'☆'.repeat(5 - stars)}<span class="sentiment">${escapeHtml(item.sentiment || 'neutro')}</span></div>
        <div class="news-card-title">${escapeHtml(item.title || 'Sem titulo')}</div>
        <div class="news-card-meta">${escapeHtml(formatNewsDate(item.published_at))}${authors}<br>${escapeHtml(item.rating_reason || 'Classificacao por relevancia operacional.')}</div>
        ${detail}
        <div class="news-card-actions">
          <a href="${escapeHtml(item.url || '#')}" target="_blank" rel="noopener noreferrer">${escapeHtml(linkLabelByType[type] || 'Abrir fonte')}</a>
          ${pdfLink}
        </div>
      `;
      return card;
    };

    visibleSections.forEach(section => {
      const topic = document.createElement('section');
      topic.className = 'news-topic';
      topic.innerHTML = `
        <div class="news-topic-header">
          <div>
            <div class="news-topic-title">${escapeHtml(section.title || 'Topico')}</div>
            <div class="news-topic-subtitle">${escapeHtml(section.subtitle || '')}</div>
          </div>
          <div class="news-topic-count">${section.items.length} itens</div>
        </div>
        <div class="news-grid"></div>
      `;
      const topicGrid = topic.querySelector('.news-grid');
      section.items.forEach(item => topicGrid.appendChild(renderCard(item)));
      grid.appendChild(topic);
    });

  } catch (error) {
    console.error('Erro ao carregar noticias de IA:', error);
    grid.innerHTML = '<div class="empty-state">Falha ao carregar o radar de IA agora.</div>';
  }
}

function arquivoParaDataUrl(file) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();

    reader.onload = () => resolve({
      name: file.name,
      type: file.type,
      data_url: reader.result
    });

    reader.onerror = reject;
    reader.readAsDataURL(file);
  });
}

async function enviarChatIa() {
  const input = document.getElementById('chatIaInput');
  const btn = document.getElementById('chatIaSendBtn');

  if (!input || !btn) {
    return;
  }

  const pergunta = input.value.trim();

  if (!pergunta && !chatIaState.attachments.length) {
    return;
  }

  const textoUsuario = pergunta || '[Imagem anexada]';

  renderChatMessage('user', textoUsuario);

  chatIaState.messages.push({
    role: 'user',
    content: textoUsuario
  });

  input.value = '';
  input.style.height = 'auto';

  btn.disabled = true;
  btn.textContent = 'Pensando...';

  renderChatMessage('assistant', 'Analisando...');
  const messagesBox = document.getElementById('chatIaMessages');
  const typingBubble = messagesBox && messagesBox.lastElementChild
    ? messagesBox.lastElementChild.querySelector('.chat-bubble')
    : null;

  try {
    const imagens = [];

    for (const file of chatIaState.attachments) {
      imagens.push(await arquivoParaDataUrl(file));
    }

    const historico = chatIaState.messages.slice(-12);

    const response = await fetch('/api/local-llm/action', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        pergunta: textoUsuario,
        historico,
        imagens
      })
    });

    const data = await response.json();
    const resposta = data.resposta || data.message || 'A IA não retornou resposta.';

    if (typingBubble) {
      typingBubble.textContent = resposta;
    } else {
      renderChatMessage('assistant', resposta);
    }

    chatIaState.messages.push({
      role: 'assistant',
      content: resposta
    });

  } catch (error) {
    console.error('Erro no Chat IA:', error);

    if (typingBubble) {
      typingBubble.textContent = 'Erro ao consultar a IA local.';
    } else {
      renderChatMessage('assistant', 'Erro ao consultar a IA local.');
    }

  } finally {
    chatIaState.attachments = [];
    renderChatIaAttachments();

    btn.disabled = false;
    btn.textContent = 'Enviar';

    input.focus();
  }
}


let heimdallVoice = null;

function carregarVozHeimdall() {
  const voices = window.speechSynthesis.getVoices();
  const preferredVoiceName = localStorage.getItem('heimdallVoiceName') || '';

  heimdallVoice =
    voices.find(v => v.name === preferredVoiceName) ||
    voices.find(v =>
      v.lang.toLowerCase() === 'pt-br' &&
      v.name.toLowerCase().includes('daniel')
    ) ||
    voices.find(v =>
      v.lang.toLowerCase() === 'pt-br' &&
      v.name.toLowerCase().includes('antonio')
    ) ||
    voices.find(v =>
      v.lang.toLowerCase() === 'pt-br' &&
      v.name.toLowerCase().includes('ricardo')
    ) ||
    voices.find(v =>
      v.lang.toLowerCase() === 'pt-br' &&
      v.name.toLowerCase().includes('male')
    ) ||
    voices.find(v =>
      v.lang.toLowerCase() === 'pt-br'
    ) ||
    voices.find(v =>
      v.lang.toLowerCase().startsWith('pt')
    ) ||
    voices[0] ||
    null;
}

function prepararTextoVoz(texto) {
  return String(texto || '')
    .replace(/Heimdall/g, 'Ráimdól')
    .replace(/Slack/g, 'Islék')
    .replace(/IA/g, 'I A')
    .replace(/KPI/g, 'K P I')
    .replace(/e-mails/g, 'êmaiouss')
    .replace(/E-mails/g, 'Êmaiouss')
    .replace(/\s+/g, ' ')
    .trim();
}

function falarHeimdall(texto) {
  if (!texto || !('speechSynthesis' in window)) {
    return;
  }

  window.speechSynthesis.cancel();

  carregarVozHeimdall();

  const fala = new SpeechSynthesisUtterance(prepararTextoVoz(texto));

  const voiceBox = document.getElementById('voiceSpeakingBox');
  const voiceSpeakingText = document.getElementById('voiceSpeakingText');

  if (voiceBox) {
    voiceBox.classList.add('active');
  }

  if (voiceSpeakingText) {
    voiceSpeakingText.textContent = texto;
  }

  fala.lang = 'pt-BR';
  fala.voice = heimdallVoice;

  fala.rate = 0.99;
  fala.pitch = 1;
  fala.volume = 1;

  fala.onend = () => {
  const voiceBox = document.getElementById('voiceSpeakingBox');

  if (voiceBox) {
    voiceBox.classList.remove('active');
  }
};

fala.onerror = () => {
  const voiceBox = document.getElementById('voiceSpeakingBox');

  if (voiceBox) {
    voiceBox.classList.remove('active');
  }
};

  window.speechSynthesis.speak(fala);
}

if ('speechSynthesis' in window) {
  window.speechSynthesis.onvoiceschanged = () => {
    carregarVozHeimdall();
    populateVoiceSelect();
  };
  carregarVozHeimdall();
}


@keyframes neuralPulse {
  0%, 100% { opacity: .35; filter: drop-shadow(0 0 3px rgba(77,168,247,.25)); }
  50% { opacity: 1; filter: drop-shadow(0 0 10px rgba(140,255,195,.65)); }
}

@keyframes neuralDash {
  to { stroke-dashoffset: -28; }
}

@keyframes brainFloat {
  0%, 100% { transform: translate(-50%, -50%) translateY(0); }
  50% { transform: translate(-50%, -50%) translateY(-6px); }
}

@keyframes coreSpin {
  to { transform: translate(-50%, -50%) rotate(360deg); }
}

@keyframes coreGlow {
  0%, 100% { box-shadow: 0 0 26px rgba(77,168,247,.24), inset 0 0 24px rgba(140,255,195,.16); }
  50% { box-shadow: 0 0 52px rgba(140,255,195,.34), inset 0 0 34px rgba(77,168,247,.24); }

}

.brain-links {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 1;
}

.brain-links path {
  fill: none;
  stroke: rgba(102, 196, 255, .58);
  stroke-width: 1;
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-dasharray: 3 7;
  stroke-dashoffset: 0;
  vector-effect: non-scaling-stroke;
  animation: neuralDash 3.6s linear infinite, neuralPulse 2.8s ease-in-out infinite;
}

.brain-links circle {
  display: none;
}

.brain-shape {
  display: none;
}

.brain-graphic {
  position: absolute;
  left: 50%;
  top: 49%;
  width: min(560px, 77%);
  aspect-ratio: 1.42;
  transform: translate(-50%, -50%);
  z-index: 2;
  overflow: visible;
  filter:
    drop-shadow(0 0 20px rgba(77, 168, 247, .25))
    drop-shadow(0 0 42px rgba(20, 126, 185, .18));
  animation: brainFloat 7s ease-in-out infinite;
}

.brain-graphic .brain-fill {
  fill: url(#brainGlow);
  stroke: rgba(77, 196, 255, .74);
  stroke-width: 2.2;
  vector-effect: non-scaling-stroke;
}

.brain-graphic .brain-lobe {
  fill: none;
  stroke: rgba(140, 255, 195, .44);
  stroke-width: 1.35;
  vector-effect: non-scaling-stroke;
}

.brain-graphic .brain-net {
  fill: none;
  stroke: rgba(77, 168, 247, .40);
  stroke-width: 1;
  stroke-dasharray: 5 8;
  vector-effect: non-scaling-stroke;
  animation: neuralDash 6s linear infinite;
}

.brain-graphic .brain-dot {
  fill: #8cffc3;
  opacity: .88;
  filter: drop-shadow(0 0 5px rgba(140,255,195,.8));
}

.brain-graphic .brain-stem {
  fill: rgba(32, 127, 184, .45);
  stroke: rgba(77, 168, 247, .62);
  stroke-width: 1.4;
  vector-effect: non-scaling-stroke;
}

.brain-core {
  animation: coreGlow 2.4s ease-in-out infinite;
  z-index: 4;
}

.brain-core::before,
.brain-core::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  border-radius: 50%;
  pointer-events: none;
}

.brain-core::before {
  width: 186px;
  height: 186px;
  border: 1px dashed rgba(77,168,247,.55);
  animation: coreSpin 18s linear infinite;
}

.brain-core::after {
  width: 224px;
  height: 224px;
  border: 1px solid rgba(140,255,195,.22);
  transform: translate(-50%, -50%);
}


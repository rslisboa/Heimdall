    <div class="score ${scoreClass(score)}">${score.toFixed(1)}</div>
    ${extraHtml}
  `;

  if (isCalendar) {
    div.addEventListener('click', () => {
      div.classList.toggle('open');
    });
  }

  return div;
}

function eventDateKey(e) {
  const metadata = e.metadata || {};

  const raw = e.source === 'calendar'
    ? (metadata.start || metadata.date || e.created_at || '')
    : (e.created_at || metadata.date || metadata.start || '');

  if (!raw) {
    return 'Sem data';
  }

  return toLocalDateKey(raw);
}

function formatDateTitle(dateKey) {
  if (!dateKey || dateKey === 'Sem data') {
    return 'Sem data';
  }

  const [y, m, d] = dateKey.split('-');

  if (!y || !m || !d) {
    return dateKey;
  }

  return `${d}/${m}/${y}`;
}

function groupEventsByDate(events) {
  const groups = {};

  events.forEach(e => {
    const key = eventDateKey(e);

    if (!groups[key]) {
      groups[key] = [];
    }

    groups[key].push(e);
  });

  return groups;
}

function getTodayDateKey() {
  return toLocalDateKey(new Date().toISOString());
}

function getEventSortDateValue(e) {
  const metadata = e.metadata || {};

  if (e.source === 'calendar') {
    return metadata.start || e.created_at || metadata.date || '';
  }

  return e.created_at || metadata.date || metadata.start || '';
}

function filtrarEventosVisaoGeral(events) {
  if (currentView !== 'all') {
    return events;
  }

  const todayKey = getTodayDateKey();

  return events.filter(e => {
    if (e.source !== 'calendar') {
      return true;
    }

    const dateKey = eventDateKey(e);

    return dateKey <= todayKey;
  });
}

function renderGroupedEvents(events) {
  const box = document.getElementById('events');
  box.innerHTML = '';

  const visibleEvents = filtrarEventosVisaoGeral(events || []);

  if (!visibleEvents || visibleEvents.length === 0) {
    const empty = document.createElement('div');
    empty.className = 'empty-state';
    empty.textContent = 'Nenhum item encontrado para esta visão.';
    box.appendChild(empty);
    return;
  }

  const sortedEvents = [...visibleEvents].sort((a, b) => {
    const da = String(getEventSortDateValue(a));
    const db = String(getEventSortDateValue(b));

    return db.localeCompare(da);
  });

  const groups = groupEventsByDate(sortedEvents);

  const sortedDates = Object.keys(groups)
    .filter(dateKey => {
      if (currentView !== 'all') {
        return true;
      }

      return dateKey <= getTodayDateKey();
    })
    .sort((a, b) => b.localeCompare(a));

  sortedDates.forEach((dateKey) => {
    const group = document.createElement('div');
    group.className = 'date-group';

    const header = document.createElement('button');
    header.type = 'button';
    header.className = 'date-group-header';

    header.innerHTML = `
      <span class="date-group-left">
        <span class="date-caret">▼</span>
        <span>${formatDateTitle(dateKey)}</span>
      </span>
      <span class="date-count">${groups[dateKey].length} item(ns)</span>
    `;

    const items = document.createElement('div');
    items.className = 'date-group-items';

    groups[dateKey]
      .sort((a, b) => {
        const da = String(getEventSortDateValue(a));
        const db = String(getEventSortDateValue(b));

        return db.localeCompare(da);
      })
      .forEach(e => {
        items.appendChild(renderEvent(e));
      });

    header.addEventListener('click', () => {
      group.classList.toggle('collapsed');
    });

    group.appendChild(header);
    group.appendChild(items);
    box.appendChild(group);
  });
}


function formatDateTime(value) {
  if (!value) {
    return 'N?o informado';
  }

  const dt = new Date(value);

  if (Number.isNaN(dt.getTime())) {
    return String(value);
  }

  return dt.toLocaleString('pt-BR', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });
}

function formatPeopleList(list) {
  if (!Array.isArray(list) || list.length === 0) {
    return 'N?o informado';

<script>
const voiceLanguage = "{{ voice_language }}";
let aiNewsCache = null;
let aiNewsPreloadPromise = null;
let aiNewsPreloadReady = false;
let newsSearchTerm = '';
let emailSearchTerm = '';
let latestEmailExecutiveState = null;
const AI_NEWS_DAILY_CACHE_KEY = 'heimdallAiNewsDailyCache';
const AI_NEWS_BOOT_TIMEOUT_MS = 15000;

function getAiNewsLocalDateKey() {
  const now = new Date();
  const y = now.getFullYear();
  const m = String(now.getMonth() + 1).padStart(2, '0');
  const d = String(now.getDate()).padStart(2, '0');
  return `${y}-${m}-${d}`;
}

function readAiNewsDailyCache() {
  try {
    const cached = JSON.parse(localStorage.getItem(AI_NEWS_DAILY_CACHE_KEY) || 'null');
    if (cached && cached.date === getAiNewsLocalDateKey() && cached.data) {
      return cached.data;
    }
  } catch (error) {
    console.warn('Cache diario do radar de IA invalido:', error);
  }

  return null;
}

function writeAiNewsDailyCache(data) {
  try {
    localStorage.setItem(AI_NEWS_DAILY_CACHE_KEY, JSON.stringify({
      date: getAiNewsLocalDateKey(),
      data
    }));
  } catch (error) {
    console.warn('Nao foi possivel salvar cache diario do radar de IA:', error);
  }
}

function preloadAiNews(force = false) {
  if (!force && aiNewsCache) {
    aiNewsPreloadReady = true;
    return Promise.resolve(aiNewsCache);
  }

  if (!force) {
    const cached = readAiNewsDailyCache();

    if (cached) {
      aiNewsCache = cached;
      aiNewsPreloadReady = true;
      return Promise.resolve(cached);
    }
  }

  if (aiNewsPreloadPromise && !force) {
    return aiNewsPreloadPromise;
  }

  aiNewsPreloadReady = false;
  const networkPromise = fetch('/api/news/ai?limit=5')
    .then(response => response.json())
    .then(data => {
      aiNewsCache = data;
      writeAiNewsDailyCache(data);
      aiNewsPreloadReady = true;
      return data;
    })
    .catch(error => {
      console.warn('Falha ao pre-carregar radar de IA:', error);
      aiNewsPreloadReady = true;
      return null;
    });

  if (force) {
    aiNewsPreloadPromise = networkPromise;
    return networkPromise;
  }

  aiNewsPreloadPromise = new Promise(resolve => {
    const timer = setTimeout(() => {
      aiNewsPreloadReady = true;
      resolve(null);
    }, AI_NEWS_BOOT_TIMEOUT_MS);

    networkPromise.then(data => {
      clearTimeout(timer);
      aiNewsPreloadReady = true;
      resolve(data);
    });
  });

  return aiNewsPreloadPromise;
}

function startHeimdallBootScreen() {
  const boot = document.getElementById('heimdallBoot');
  const canvas = document.getElementById('heimdallBootCanvas');
  const progressFill = document.getElementById('heimdallBootProgressFill');
  const status = document.getElementById('heimdallBootStatus');

  if (!boot || !canvas) {
    return;
  }

  preloadAiNews();

  const ctx = canvas.getContext('2d');
  const duration = 6000;

  let W = 0;
  let H = 0;
  let cx = 0;
  let cy = 0;
  let t = 0;
  let startedAt = performance.now();
  let animationId = null;
  let bootReady = false;
  let displayedBootProgress = 0;

  const bootMouse = {
    x: 0,
    y: 0,
    active: false
  };

  const matrixChars = 'HEIMDALL01アイウエオカキサシスセソ∑∆∏∂∇⊕⊗≡≠λΦΨΩ∞§01100110101'.split('');

  let drops = [];
  let stars = [];
  let orbs = [];
  let rings = [];
  let ringAngles = [];

  function handleBootMouseMove(event) {
  const rect = canvas.getBoundingClientRect();

  bootMouse.x = event.clientX - rect.left;
  bootMouse.y = event.clientY - rect.top;
  bootMouse.active = true;
}

function handleBootMouseLeave() {
  bootMouse.active = false;
}

  function resizeBoot() {
    W = window.innerWidth;
    H = window.innerHeight;

    canvas.width = W;
    canvas.height = H;

    cx = W / 2;
    cy = H * 0.42;

    initBootParticles();
  }

  function initBootParticles() {
    drops = [];

    const ncols = Math.floor(W / 15);

    for (let i = 0; i < ncols; i++) {
      const len = 8 + Math.floor(Math.random() * 20);

      drops.push({
        x: i * 15 + 7,
        y: Math.random() * H - H,
        speed: 1.2 + Math.random() * 2.6,
        len,
        chars: Array.from({ length: len }, () => matrixChars[Math.floor(Math.random() * matrixChars.length)]),
        ci: Math.floor(Math.random() * 3),
        op: 0.13 + Math.random() * 0.38,
        bright: Math.random() > 0.88
      });
    }

    stars = [];

    for (let i = 0; i < 190; i++) {
      stars.push({
        x: Math.random() * W,
        y: Math.random() * H,
        r: Math.random() * 1.2,
        blink: Math.random() * Math.PI * 2
      });
    }

    orbs = [];

    for (let i = 0; i < 34; i++) {
      const angle = (i / 34) * Math.PI * 2;
      const rScale = Math.min(W, H) * 0.235;

      orbs.push({
        baseAngle: angle,
        r: rScale + Math.random() * rScale * 0.18,
        speed: (Math.random() > 0.5 ? 1 : -1) * (0.004 + Math.random() * 0.011),
        size: Math.max(2, Math.min(W, H) * 0.006) + Math.random() * Math.max(1, Math.min(W, H) * 0.004),
        color: ['#00ff88', '#00ccff', '#7b5fff', '#4da8f7', '#8cffc3', '#ffffff'][Math.floor(Math.random() * 6)],
        offset: Math.random() * Math.PI * 2
      });
    }

    const rs = Math.min(W, H);

    rings = [
      { r: rs * 0.185, speed: 0.008, color: '#8cffc3', dash: [6, 8], w: 1.0, op: 0.66 },
      { r: rs * 0.250, speed: -0.005, color: '#7b5fff', dash: [12, 6], w: 1.1, op: 0.46 },
      { r: rs * 0.325, speed: 0.003, color: '#00ccff', dash: [4, 14], w: 0.9, op: 0.38 },
      { r: rs * 0.395, speed: -0.007, color: '#4da8f7', dash: [8, 10], w: 0.8, op: 0.32 }
    ];

    ringAngles = rings.map(() => 0);
  }

  function drawGrid() {
    ctx.strokeStyle = '#00ff88';
    ctx.lineWidth = 0.3;
    ctx.globalAlpha = 0.045;

    for (let x = 0; x < W; x += 30) {
      ctx.beginPath();
      ctx.moveTo(x, 0);
      ctx.lineTo(x, H);
      ctx.stroke();
    }

    for (let y = 0; y < H; y += 30) {
      ctx.beginPath();
      ctx.moveTo(0, y);
      ctx.lineTo(W, y);
      ctx.stroke();
    }

    ctx.globalAlpha = 1;
  }

  function drawStars() {
    stars.forEach(s => {
      const alpha = 0.18 + 0.48 * Math.abs(Math.sin(s.blink + t * 0.012));

      ctx.fillStyle = `rgba(255,255,255,${alpha})`;
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx.fill();
    });
  }

  function drawMatrix() {
    drops.forEach(d => {
      if (Math.random() < 0.045) {
        const idx = Math.floor(Math.random() * d.chars.length);
        d.chars[idx] = matrixChars[Math.floor(Math.random() * matrixChars.length)];
      }

      ctx.font = d.bright ? 'bold 12px monospace' : '11px monospace';

      for (let j = 0; j < d.len; j++) {
        const py = d.y - j * 14;

        if (py < -14 || py > H + 14) {
          continue;
        }

        const fade = 1 - (j / d.len);
        let color = '#00ff88';
        let alpha = fade * d.op;

        if (j === 0) {
          color = '#ffffff';
          alpha = d.bright ? .9 : .62;
        } else {
          const base = d.ci === 0 ? [0, 255, 136] : d.ci === 1 ? [0, 200, 255] : [123, 95, 255];
          color = `rgb(${base[0]},${base[1]},${base[2]})`;
          alpha = fade * d.op * (d.bright ? 1.35 : 1);
        }

        ctx.fillStyle = color;
        ctx.globalAlpha = Math.min(alpha, 1);
        ctx.fillText(d.chars[j], d.x - 5, py);
      }

      d.y += d.speed;

      if (d.y - d.len * 14 > H) {
        d.y = -20;
        d.speed = 1.2 + Math.random() * 2.6;
        d.ci = Math.floor(Math.random() * 3);
        d.bright = Math.random() > 0.88;
        d.op = 0.13 + Math.random() * 0.38;
      }
    });

    ctx.globalAlpha = 1;
  }

  function drawRings() {
    rings.forEach((rg, i) => {
      ringAngles[i] += rg.speed;

      ctx.save();
      ctx.translate(cx, cy);
      ctx.rotate(ringAngles[i]);
      ctx.setLineDash(rg.dash);
      ctx.strokeStyle = rg.color;
      ctx.globalAlpha = rg.op;
      ctx.lineWidth = rg.w;
      ctx.beginPath();
      ctx.arc(0, 0, rg.r, 0, Math.PI * 2);
      ctx.stroke();
      ctx.restore();
    });

    ctx.setLineDash([]);
    ctx.globalAlpha = 1;
  }

function drawOrbs() {
  orbs.forEach(o => {
    const ang = o.baseAngle + t * o.speed;
    const wobble = Math.sin(t * 0.02 + o.offset) * 8;

    let ox = cx + Math.cos(ang) * (o.r + wobble);
    let oy = cy + Math.sin(ang) * (o.r + wobble) * 0.55;

    let orbSize = o.size;

    if (bootReady && bootMouse.active) {
      const dx = bootMouse.x - ox;
      const dy = bootMouse.y - oy;
      const dist = Math.sqrt((dx * dx) + (dy * dy)) || 1;

      const magnetRadius = Math.min(W, H) * 0.70;
      const magnetPower = 0.90;

      if (dist < magnetRadius) {
        const influence = 1 - (dist / magnetRadius);
        const smoothForce = influence * influence;

        ox += dx * smoothForce * magnetPower;
        oy += dy * smoothForce * magnetPower;

        orbSize += smoothForce * 5;
      }
    }

    ctx.fillStyle = o.color;
    ctx.globalAlpha = 0.48 + 0.35 * Math.abs(Math.sin(t * 0.03 + o.offset));
    ctx.beginPath();
    ctx.arc(ox, oy, orbSize, 0, Math.PI * 2);
    ctx.fill();
  });

  ctx.globalAlpha = 1;
}

  function drawCore(progress) {
    const pulse = 0.90 + 0.10 * Math.sin(t * 0.055);

    // Aumentei o núcleo central aqui.
    const coreR = Math.min(W, H) * 0.145 * pulse;
    const spinnerR = coreR + 58;

    ctx.strokeStyle = '#8cffc3';
    ctx.lineWidth = 0.7;
    ctx.globalAlpha = 0.22;
    ctx.beginPath();
    ctx.arc(cx, cy, coreR + 22, 0, Math.PI * 2);
    ctx.stroke();

    ctx.globalAlpha = 0.12;
    ctx.beginPath();
    ctx.arc(cx, cy, coreR + 52, 0, Math.PI * 2);
    ctx.stroke();
    ctx.globalAlpha = 1;

    const grd = ctx.createRadialGradient(cx, cy, 0, cx, cy, coreR);
    grd.addColorStop(0, 'rgba(255,255,255,0.96)');
    grd.addColorStop(0.22, 'rgba(140,255,195,0.90)');
    grd.addColorStop(0.52, 'rgba(77,168,247,0.72)');
    grd.addColorStop(0.78, 'rgba(15,80,130,0.44)');
    grd.addColorStop(1, 'rgba(0,0,0,0)');

    ctx.fillStyle = grd;
    ctx.beginPath();
    ctx.arc(cx, cy, coreR, 0, Math.PI * 2);
    ctx.fill();

    ctx.strokeStyle = 'rgba(77,168,247,.18)';
    ctx.lineWidth = 8;
    ctx.beginPath();
    ctx.arc(cx, cy, spinnerR, 0, Math.PI * 2);
    ctx.stroke();

    ctx.strokeStyle = '#4da8f7';
    ctx.lineWidth = 8;
    ctx.lineCap = 'round';
    ctx.shadowColor = '#4da8f7';
    ctx.shadowBlur = 20;
    ctx.beginPath();
    ctx.arc(
      cx,
      cy,
      spinnerR,
      -Math.PI / 2,
      -Math.PI / 2 + (Math.PI * 2 * progress)
    );
    ctx.stroke();
    ctx.shadowBlur = 0;

    ctx.textAlign = 'center';

    if (bootReady) {
      ctx.font = '900 30px ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas';
      ctx.fillStyle = '#8cffc3';
      ctx.shadowColor = '#8cffc3';
      ctx.shadowBlur = 20;
      ctx.fillText('READY!', cx, cy + coreR + 96);
      ctx.shadowBlur = 0;
    } else {
      ctx.font = '900 13px ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas';
      ctx.fillStyle = '#d8e1f5';
      ctx.fillText(`${Math.floor(progress * 100)}%`, cx, cy + coreR + 76);
    }

    ctx.textAlign = 'left';
  }

  function drawHud() {
    const pad = Math.round(W * 0.04);
    const vpad = Math.round(H * 0.085);
    const fs = Math.max(10, Math.round(W * 0.010));

    ctx.font = `bold ${fs}px monospace`;
    ctx.fillStyle = '#8cffc3';
    ctx.globalAlpha = 0.58;
    ctx.fillText('// HEIMDALL PORTAL v1.0', pad, vpad);

    ctx.textAlign = 'right';
    ctx.fillText('SYSTEM: ONLINE', W - pad, vpad);
    ctx.textAlign = 'left';

    ctx.strokeStyle = '#8cffc3';
    ctx.lineWidth = 0.6;
    ctx.globalAlpha = 0.26;

    const cl = pad - 6;
    const cr = W - pad + 6;
    const ct = vpad + 8;
    const cb = H - vpad + 8;
    const arm = 18;

    [[cl, ct, arm, arm], [cr, ct, -arm, arm], [cl, cb, arm, -arm], [cr, cb, -arm, -arm]].forEach(([x, y, dx, dy]) => {
      ctx.beginPath();
      ctx.moveTo(x, y);
      ctx.lineTo(x + dx, y);
      ctx.moveTo(x, y);
      ctx.lineTo(x, y + dy);
      ctx.stroke();
    });

    ctx.globalAlpha = 1;
  }

  function drawScanLine() {
    const sy = (t * 1.4) % H;

    ctx.strokeStyle = '#00ccff';
    ctx.lineWidth = 0.8;
    ctx.globalAlpha = 0.06;
    ctx.beginPath();
    ctx.moveTo(0, sy);
    ctx.lineTo(W, sy);
    ctx.stroke();
    ctx.globalAlpha = 1;
  }

  function finalizarBootScreen() {
  boot.classList.remove('ready');
  boot.classList.add('done');

  window.removeEventListener('resize', resizeBoot);

  boot.removeEventListener('mousemove', handleBootMouseMove);
  boot.removeEventListener('mouseleave', handleBootMouseLeave);

  setTimeout(() => {
    if (animationId) {
      cancelAnimationFrame(animationId);
    }

    boot.remove();
  }, 720);
}

  function frame(now) {
    const elapsed = now - startedAt;
    const animationProgress = Math.min(elapsed / duration, 1);
    const targetProgress = aiNewsPreloadReady
      ? animationProgress
      : Math.min(animationProgress, 0.92);
    displayedBootProgress += (targetProgress - displayedBootProgress) * 0.075;

    if (targetProgress >= 1 && displayedBootProgress > 0.995) {
      displayedBootProgress = 1;
    }

    const progress = displayedBootProgress;

    if (progressFill) {
      progressFill.style.width = `${Math.floor(progress * 100)}%`;
    }

    if (status) {
      status.textContent = aiNewsPreloadReady
        ? `BOOT SEQUENCE ${Math.floor(progress * 100)}%`
        : `CARREGANDO RADAR DE IA ${Math.floor(progress * 100)}%`;
    }

    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = '#000008';
    ctx.fillRect(0, 0, W, H);

    drawGrid();
    drawStars();
    drawMatrix();
    drawRings();
    drawOrbs();
    drawCore(progress);
    drawHud();
    drawScanLine();

    t++;

    if (animationProgress >= 1 && aiNewsPreloadReady && progress >= 1 && !bootReady) {
      bootReady = true;
      boot.classList.add('ready');

      if (progressFill) {
        progressFill.style.width = '100%';
      }

      if (status) {
        status.textContent = 'BOOT SEQUENCE 100%';
      }

      boot.addEventListener('click', finalizarBootScreen, { once: true });
    }

    animationId = requestAnimationFrame(frame);
  }

    resizeBoot();

    window.addEventListener('resize', resizeBoot);
    boot.addEventListener('mousemove', handleBootMouseMove);
    boot.addEventListener('mouseleave', handleBootMouseLeave);

    animationId = requestAnimationFrame(frame);
}


const lineRevealPlugin = {
  id: 'lineRevealPlugin',

  beforeDatasetDraw(chart, args, pluginOptions) {
    if (args.index !== 1) {
      return;
    }

    const chartArea = chart.chartArea;

    if (!chartArea) {
      return;
    }

    const duration = pluginOptions.duration || 1400;

    if (!chart.$lineRevealStarted) {
      chart.$lineRevealStarted = performance.now();
    }

    const elapsed = performance.now() - chart.$lineRevealStarted;
    const progress = Math.min(elapsed / duration, 1);

    const ctx = chart.ctx;

    ctx.save();
    chart.$lineRevealClipping = true;

    ctx.beginPath();
    ctx.rect(
      chartArea.left,
      chartArea.top,
      (chartArea.right - chartArea.left) * progress,
      chartArea.bottom - chartArea.top
    );
    ctx.clip();

    if (progress < 1) {
      requestAnimationFrame(() => chart.draw());
    }
  },

  afterDatasetDraw(chart, args) {
    if (args.index !== 1 || !chart.$lineRevealClipping) {
      return;
    }

    chart.ctx.restore();
    chart.$lineRevealClipping = false;
  }
};

const lineValueLabelsPlugin = {
  id: 'lineValueLabelsPlugin',

  afterDatasetsDraw(chart) {
    const chartArea = chart.chartArea;

    if (!chartArea) {
      return;
    }

    const duration = chart.options.plugins.lineRevealPlugin.duration || 1400;
    const started = chart.$lineRevealStarted || performance.now();
    const elapsed = performance.now() - started;
    const progress = Math.min(elapsed / duration, 1);
    const clipRight = chartArea.left + ((chartArea.right - chartArea.left) * progress);

    const ctx = chart.ctx;

    chart.data.datasets.forEach((dataset, datasetIndex) => {
      if (dataset.type !== 'line') {
        return;
      }

      const meta = chart.getDatasetMeta(datasetIndex);

      ctx.save();
      ctx.font = '800 11px ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas';
      ctx.fillStyle = '#4da8f7';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'bottom';

      meta.data.forEach((point, index) => {
        const value = Number(dataset.data[index]);

        if (Number.isNaN(value)) {
          return;
        }

        if (point.x > clipRight) {
          return;
        }

        ctx.fillText(`${value.toFixed(1)}%`, point.x, point.y - 8);
      });

      ctx.restore();
    });
  }
};

function formatActivityDayLabel(day) {
  if (!day) {
    return 'Sem data';
  }

  const parts = String(day).split('-');

  if (parts.length !== 3) {
    return day;
  }

  return `${parts[2]}/${parts[1]}`;
}

function calculateDailyVariation(values) {
  return values.map((currentValue, index) => {
    const current = Number(currentValue || 0);

    if (index === 0) {
      return 0;
    }

    const previous = Number(values[index - 1] || 0);

    if (previous === 0) {
      return current > 0 ? 100 : 0;
    }

    return Number((((current - previous) / previous) * 100).toFixed(1));
  });
}


}

#voiceTestBtn {
  display: block;
  width: 100%;
}

@media (max-width: 1180px) {
  .config-grid {
    grid-template-columns: repeat(2, minmax(260px, 1fr));
  }
}

@media (max-width: 720px) {
  .config-grid {

const eventosFalados = new Set();
let eventosFaladosInicializados = false;

function normalizarFonteEvento(e) {
  return String(e.source || '').toLowerCase();
}

function montarChaveEventoVoz(e) {
  return [
    e.id || '',
    e.external_id || '',
    e.source || '',
    e.title || '',
    e.detail || '',
    e.created_at || '',
    e.metadata.start || '',
    e.metadata.message_id || '',
    e.metadata.sender || '',
    e.metadata.from || ''
  ].join('|');
}

function extrairEventoDoWebSocket(data) {
  return data.event || data.payload || data.item || data.data || null;
}

function extrairNomeRemetente(valor) {
  const raw = String(valor || '').trim();

  if (!raw) {
    return 'remetente não identificado';
  }

  const match = raw.match(/^"([^"<]+)"\s*</);
  let nome = match && match[1] ? match[1].trim() : raw;

  nome = nome
    .replace(/["']/g, '')
    .trim();

  if (nome.includes('@')) {
    nome = nome.split('@')[0];
  }

  nome = nome
    .replace(/[._-]+/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();

  return nome || 'remetente não identificado';
}

function normalizarTextoComparacao(texto) {
  return String(texto || '')
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^\w\s]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

function resumirTextoVozEmail(texto, assunto = '') {
  let resumo = String(texto || '')
    .replace(/<[^>]*>/g, ' ')
    .replace(/https:\/\/\S+/g, '')
    .replace(/\s+/g, ' ')
    .trim();

  const assuntoLimpo = String(assunto || '').trim();

  if (assuntoLimpo) {
    resumo = resumo
      .replace(new RegExp(assuntoLimpo.replace(/[.*+^${}()|[\]\\]/g, '\\$&'), 'gi'), '')
      .replace(/\s+/g, ' ')
      .trim();
  }

  const resumoNorm = normalizarTextoComparacao(resumo);
  const assuntoNorm = normalizarTextoComparacao(assuntoLimpo);

  if (!resumoNorm || resumoNorm === assuntoNorm || assuntoNorm.includes(resumoNorm) || resumoNorm.includes(assuntoNorm)) {
    return '';
  }

  return resumo.slice(0, 220);
}

function montarTextoAlertaVoz(e) {
  const source = normalizarFonteEvento(e);
  const title = e.title || 'sem título';
  const metadata = e.metadata || {};

    if (source === 'email') {
    const nomeRemetente = extrairNomeRemetente(
      metadata.sender ||
      metadata.from ||
      ''
    );

    const resumo = resumirTextoVozEmail(
      metadata.snippet ||
      metadata.body ||
      metadata.summary ||
      e.detail ||
      '',
      title
    );

    if (resumo) {
      return `Rodrigo, novo email de ${nomeRemetente}. Assunto: ${title}. Resumo: ${resumo}.`;
    }

    return `Rodrigo, novo email de ${nomeRemetente}. Assunto: ${title}.`;
  }

  if (source === 'calendar') {
    const start = metadata.start || e.created_at || '';
    let horario = '';

    if (start) {
      const dt = new Date(start);

      if (!Number.isNaN(dt.getTime())) {
        horario = dt.toLocaleTimeString('pt-BR', {
          hour: '2-digit',
          minute: '2-digit'
        });
      }
    }

    if (horario) {
      return `Rodrigo, nova reuni?o marcada para ${horario}. ${title}.`;
    }

    return `Rodrigo, nova reuni?o marcada. ${title}.`;
  }

  return '';
}

async function inicializarEventosFalados() {
  try {
    const events = await fetch('/api/events?limit=300').then(r => r.json());

    events
      .filter(e => e.source === 'email' || e.source === 'calendar')
      .forEach(e => {
        eventosFalados.add(montarChaveEventoVoz(e));
      });

    eventosFaladosInicializados = true;

    console.log(`Voz automática inicializada com ${eventosFalados.size} evento(s) já conhecidos.`);

  } catch (error) {
    console.warn('Falha ao inicializar eventos já conhecidos para voz:', error);
    eventosFaladosInicializados = true;
  }
}

async function falarNovoEmailOuReuniao(data) {
  try {
    if (!eventosFaladosInicializados) {
      await inicializarEventosFalados();
    }

    const eventoDoSocket = extrairEventoDoWebSocket(data);

    if (eventoDoSocket) {
      const sourceSocket = normalizarFonteEvento(eventoDoSocket);

      if (sourceSocket === 'email' || sourceSocket === 'calendar') {
        const chaveSocket = montarChaveEventoVoz(eventoDoSocket);

        if (!eventosFalados.has(chaveSocket)) {
          eventosFalados.add(chaveSocket);

          const textoSocket = montarTextoAlertaVoz(eventoDoSocket);

          if (textoSocket) {
            falarHeimdall(textoSocket);
          }
        }

        return;
      }
    }

    const events = await fetch('/api/events?limit=30').then(r => r.json());

    const novos = events
      .filter(e => e.source === 'email' || e.source === 'calendar')
      .filter(e => !eventosFalados.has(montarChaveEventoVoz(e)))
      .sort((a, b) => String(a.created_at || '').localeCompare(String(b.created_at || '')));

    if (!novos.length) {
      return;
    }

    const evento = novos[novos.length - 1];
    const chave = montarChaveEventoVoz(evento);

    eventosFalados.add(chave);

    const texto = montarTextoAlertaVoz(evento);

    if (texto) {
      falarHeimdall(texto);
    }

  } catch (error) {
    console.warn('Falha ao falar novo evento:', error);
  }
}


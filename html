  grid-template-columns: 300px minmax(460px, 1fr) 260px;
  gap: 18px;
  padding: 18px;
  margin-bottom: 16px;
  border: 1px solid rgba(77, 168, 247, .28);
  background:
    linear-gradient(180deg, rgba(7, 11, 20, .98), rgba(10, 14, 23, .96)),
    #090d16;
  position: relative;
  overflow: hidden;
}

.command-center::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(77, 168, 247, .07) 1px, transparent 1px),
    linear-gradient(90deg, rgba(77, 168, 247, .06) 1px, transparent 1px);
  background-size: 34px 34px;
  opacity: .35;
  pointer-events: none;
}

.command-column,
.brain-stage,
.command-side {
  position: relative;
  z-index: 1;
}

.command-kicker {
  color: #8cffc3;
  border: 1px solid rgba(140, 255, 195, .28);
  display: inline-flex;
  padding: 8px 12px;
  font-size: 11px;
  font-weight: 900;
  letter-spacing: 1.5px;
  margin-bottom: 18px;
}

.command-title {
  color: #e9f7ff;
  font-size: clamp(44px, 5.4vw, 76px);
  line-height: .9;
  font-weight: 900;
  letter-spacing: 2px;
  text-shadow: 0 0 22px rgba(77, 168, 247, .35);
  margin: 0 0 20px;
}

.command-subtitle {
  color: #9fb0d0;
  font-size: 18px;
  line-height: 1.5;
  font-weight: 800;
  margin-bottom: 26px;
}

.core-card {
  border: 1px solid rgba(77, 168, 247, .24);
  background: rgba(12, 18, 31, .82);
  padding: 16px;
  margin-bottom: 14px;
}

.core-card-title {
  color: #8cffc3;
  font-size: 14px;
  font-weight: 900;
  letter-spacing: 1px;
  margin-bottom: 8px;
}

.core-card-text {
  color: #a7b5d4;
  font-size: 12px;
  line-height: 1.55;
  font-weight: 700;
}

.brain-stage {
  min-height: 580px;
}

.brain-canvas {
  position: absolute;
  inset: 50px 28px 70px;
  border: 1px solid rgba(77, 168, 247, .14);
}

.brain-shape {
  position: absolute;
  left: 50%;
  top: 48%;
  width: min(430px, 64%);
  aspect-ratio: 1.35;
  transform: translate(-50%, -50%);
  border: 1px solid rgba(77, 168, 247, .46);
  clip-path: polygon(13% 42%, 20% 20%, 43% 15%, 51% 24%, 67% 15%, 86% 28%, 88% 54%, 77% 75%, 55% 78%, 46% 88%, 32% 78%, 16% 70%);
  background:
    radial-gradient(circle at 32% 42%, rgba(140, 255, 195, .28), transparent 30%),
    radial-gradient(circle at 62% 38%, rgba(77, 168, 247, .34), transparent 34%),
    linear-gradient(135deg, rgba(77, 168, 247, .16), rgba(9, 15, 26, .28));
  box-shadow: 0 0 48px rgba(77, 168, 247, .20), inset 0 0 40px rgba(77, 168, 247, .18);
}

.brain-shape::before {
  content: "";
  position: absolute;
  inset: 14px;
  background-image:
    radial-gradient(circle, rgba(140,255,195,.9) 0 1.5px, transparent 2px),
    linear-gradient(35deg, transparent 48%, rgba(77,168,247,.26) 49%, transparent 51%),
    linear-gradient(145deg, transparent 48%, rgba(77,168,247,.20) 49%, transparent 51%);
  background-size: 44px 44px, 72px 72px, 90px 90px;
  opacity: .85;
}

.brain-core {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 138px;
  height: 138px;
  border-radius: 50%;
  border: 1px solid #8cffc3;
  background: rgba(7, 13, 24, .94);
  color: #e9f7ff;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 7px;
  font-family: inherit;
  font-weight: 900;
  letter-spacing: 1px;
  cursor: pointer;
  box-shadow: 0 0 34px rgba(140, 255, 195, .22), inset 0 0 22px rgba(77, 168, 247, .22);
}

.brain-core span {
  color: #8cffc3;
  font-size: 11px;
}

.agent-node {
  position: absolute;
  width: 122px;
  min-height: 96px;
  border: 1px solid rgba(181, 255, 32, .46);
  background: rgba(11, 17, 30, .94);
  color: #d8e1f5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font-family: inherit;
  cursor: pointer;
  transform: translate(-50%, -50%);
  transition: transform .15s ease, border-color .15s ease, box-shadow .15s ease;
}

.agent-node:hover,
.agent-node.active {
  transform: translate(-50%, -50%) scale(1.04);
  border-color: var(--lime);
  box-shadow: 0 0 24px rgba(181, 255, 32, .18);
}

.agent-node .agent-symbol {
  color: #4da8f7;
  width: 30px;
  height: 28px;
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 0;
  line-height: 1;
}

.agent-node .agent-symbol::before,
.agent-node .agent-symbol::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
}

.agent-symbol.icon-text::before {
  content: attr(data-icon);
  position: static;
  color: #4da8f7;
  font-size: 22px;
  font-weight: 900;
  text-shadow: 0 0 10px rgba(77, 168, 247, .38);
}

.agent-symbol.icon-calendar::before {
  width: 22px;
  height: 20px;
  border: 2px solid #4da8f7;
  border-top-width: 5px;
  border-radius: 3px;
  box-shadow: 0 0 10px rgba(77, 168, 247, .32);
}

.agent-symbol.icon-calendar::after {
  width: 14px;
  height: 2px;
  background: #4da8f7;
  top: 14px;
  left: 8px;
  box-shadow: 0 5px 0 rgba(77, 168, 247, .72);
}

.agent-symbol.icon-check::before {
  width: 18px;
  height: 10px;
  border-left: 3px solid #4da8f7;
  border-bottom: 3px solid #4da8f7;
  transform: rotate(-45deg) translateY(-2px);
  box-shadow: -4px 4px 10px rgba(77, 168, 247, .25);
}

.agent-symbol.icon-diamond::before {
  width: 18px;
  height: 18px;
  border: 2px solid #4da8f7;
  transform: rotate(45deg);
  box-shadow: 0 0 10px rgba(77, 168, 247, .36);
}

.agent-symbol.icon-voice::before {
  width: 18px;
  height: 18px;
  border: 2px solid #4da8f7;
  border-radius: 50%;
  box-shadow: 0 0 0 5px rgba(77, 168, 247, .10), 0 0 12px rgba(77, 168, 247, .36);
}

.agent-symbol.icon-gear::before {
  width: 22px;
  height: 22px;
  border: 2px dashed #4da8f7;
  border-radius: 50%;
  box-shadow: 0 0 10px rgba(77, 168, 247, .34);
}

.agent-symbol.icon-gear::after {
  width: 7px;
  height: 7px;
  border: 2px solid #4da8f7;
  border-radius: 50%;
}

.agent-node .agent-label {
  font-size: 12px;
  font-weight: 900;
  letter-spacing: .8px;
  text-align: center;
}

.agent-node .agent-status {
  color: var(--lime);
  font-size: 10px;
  font-weight: 900;
}

.agent-node.offline {
  border-color: rgba(120, 130, 140, .34);
  color: #6f7c8d;
  cursor: not-allowed;
  filter: grayscale(.55);
  opacity: .72;
}

.agent-node.offline:hover {
  transform: translate(-50%, -50%);
  border-color: rgba(120, 130, 140, .34);
  box-shadow: none;
}

.agent-node.offline .agent-symbol,
.agent-node.offline .agent-status {
  color: #7a8494;
}

.node-email { left: 27%; top: 23%; }
.node-calendar { left: 50%; top: 15%; }
.node-slack { left: 73%; top: 23%; }
.node-task { left: 15%; top: 44%; }
.node-chatia { left: 85%; top: 44%; }
.node-news { left: 19%; top: 67%; }

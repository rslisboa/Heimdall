.language-tutor-page {
  min-height: calc(100vh - 108px);
  background:
    radial-gradient(circle at top left, rgba(140,255,195,.08), transparent 32%),
    radial-gradient(circle at bottom right, rgba(77,168,247,.10), transparent 34%),
    #0c0e15;
  border: 1px solid #1c2236;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.language-tutor-header {
  padding: 18px 20px;
  border-bottom: 1px solid #1c2236;
  background: rgba(15, 18, 32, .92);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}

.language-tutor-header h2 {
  margin: 0;
  color: #d8e1f5;
  font-size: 24px;
  font-weight: 900;
  letter-spacing: .8px;
}

.language-tutor-header p {
  margin: 6px 0 0;
  color: #8b9cc0;
  font-size: 12px;
  font-weight: 700;
  line-height: 1.5;
}

.language-tutor-shell {
  flex: 1;
  display: grid;
  grid-template-columns: 290px minmax(0, 1fr);
  gap: 1px;
  background: #1c2236;
  min-height: 0;
}

.language-tutor-side,
.language-tutor-main {
  background: #0c0e15;
}

.language-tutor-side {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.language-side-card {
  border: 1px solid #1c2236;
  background: #0f1220;
  padding: 14px;
}

.language-side-title {
  color: #8cffc3;
  font-size: 11px;
  font-weight: 900;
  letter-spacing: 1.4px;
  margin-bottom: 10px;
}

.language-side-text {
  color: #9fb0d0;
  font-size: 12px;
  line-height: 1.65;
  font-weight: 700;
}

.language-tutor-main {
  min-width: 0;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.language-chat {
  flex: 1;
  max-height: none;
  min-height: 0;
  overflow: auto;
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.language-toolbar {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 110px 110px;
  gap: 10px;
  padding: 14px;
  border-top: 1px solid #1c2236;
  background: rgba(15, 18, 32, .95);
  margin-bottom: 0;
}

.language-select,
.language-input {
  border: 1px solid #27314a;
  background: #0c0e15;
  color: #dde3f0;
  padding: 12px 14px;
  font-family: inherit;
  font-weight: 800;
  outline: none;
}

.language-select {
  width: 100%;
  margin-bottom: 10px;
}

.language-input:focus,
.language-select:focus {
  border-color: #8cffc3;
  box-shadow: 0 0 0 2px rgba(140,255,195,.08);
}

.language-button {
  border: 1px solid #4da8f7;
  background: #081428;
  color: #4da8f7;
  padding: 11px 13px;
  font-family: inherit;
  font-weight: 900;
  cursor: pointer;
}

.language-button.primary {
  border-color: #8cffc3;
  background: #0b2a20;
  color: #8cffc3;
}

.language-button.listening {
  border-color: #f06060;
  color: #f06060;
  animation: pulse 1s infinite;
}

.language-status {
  color: #9fb0d0;
  font-size: 12px;
  font-weight: 800;
  line-height: 1.55;
}

.language-msg {
  border: 1px solid #1c2236;
  background: #0f1220;
  padding: 13px 14px;
  color: #d8e1f5;
  font-size: 14px;
  line-height: 1.65;
  font-weight: 700;
  max-width: 82%;
  white-space: pre-wrap;
}

.language-msg.user {
  align-self: flex-end;
  border-color: rgba(77, 168, 247, .38);
  background: #081428;
}

.language-msg.teacher {
  align-self: flex-start;
  border-color: rgba(140, 255, 195, .30);
  background: #0d1516;
}

.language-msg-label {
  color: #8cffc3;
  font-size: 10px;
  font-weight: 900;
  letter-spacing: 1px;
  margin-bottom: 5px;
  text-transform: uppercase;
}

@media(max-width: 900px) {
  .language-tutor-shell {
    grid-template-columns: 1fr;
  }

  .language-toolbar {
    grid-template-columns: 1fr;
  }
}

/* =========================================================

function connectWs() {
  const protocol = location.protocol === 'https:' ? 'wss' : 'ws';
  const ws = new WebSocket(`${protocol}://${location.host}/ws`);
  ws.onopen = () => ws.send('ping');
  ws.onmessage = async (msg) => {
    const data = JSON.parse(msg.data);

  if (data.type === 'event') {
    loadEvents();
    loadKpis();
    loadActivity();

    await falarNovoEmailOuReuniao(data);
  }

  if (data.type === 'task_interaction') {
    await handleTaskInteraction(data);
  }

  if (data.type === 'email_executive') {
    await handleEmailExecutiveInteraction(data.state);
  }

  if (data.type === 'coders_update') {
    const payload = data.data || {};
    const stream = document.getElementById('codersStream');
    if (stream) {
      const agents = Array.isArray(payload.agents) ? payload.agents : [];
      agents.forEach(a => updateCoderAgentCard(a, payload.checked_at || new Date().toISOString()));
      
      const timeStr = new Date(payload.checked_at || new Date()).toLocaleTimeString('pt-BR');
      stream.textContent = `[${timeStr}] Auditoria Continua em Tempo Real\n\n` + [
        payload.summary || 'Auditoria concluida.',
        '',
        ...(Array.isArray(payload.risks) ? payload.risks.map(risk => `Risco: ${risk}`) : []),
        ...(Array.isArray(payload.recommendations) ? payload.recommendations.map(item => `Recomendacao: ${item}`) : [])
      ].filter(Boolean).join('\n');
    }
  }

  if (data.type === 'log') {
    renderLog({
      level: data.level || 'INFO',
      source: data.source || 'system',
      message: data.message || '',
      created_at: new Date().toISOString()
    });
  }

  if (data.type === 'voice') {
    renderLog({
      level: 'INFO',
      source: 'voice',
      message: `${data.text} -> ${data.answer.answer || ''}`,
      created_at: new Date().toISOString()
    });
  }
  };
  ws.onclose = () => setTimeout(connectWs, 2000);
  setInterval(() => { if (ws.readyState === 1) ws.send('ping'); }, 15000);
}

function normalizeDisplayText(value) {
  const text = String(value == null ? '' : value);

  if (!/[\u00C3\u00C2\u00E2\u00F0\uFFFD]|\bn\?o\b|\bN\?o\b/.test(text)) {
    return text;
  }

  try {
    const decoded = decodeURIComponent(escape(text));
    const originalNoise = (text.match(/[\u00C3\u00C2\u00E2\u00F0\uFFFD]|\?/g) || []).length;
    const decodedNoise = (decoded.match(/[\u00C3\u00C2\u00E2\u00F0\uFFFD]|\?/g) || []).length;

    if (decodedNoise < originalNoise) {
      return decoded;
    }
  } catch (error) {
    // Fallback below handles partial mojibake strings.
  }

  return text
    .replace(/N\u00C3\u00A3o/g, 'Não')
    .replace(/n\u00C3\u00A3o/g, 'não')
    .replace(/N\?o/g, 'Não')
    .replace(/n\?o/g, 'não')
    .replace(/Reuni\u00C3\u00A3o/g, 'Reunião')
    .replace(/reuni\u00C3\u00A3o/g, 'reunião')
    .replace(/Almo\u00C3\u00A7o/g, 'Almoço')
    .replace(/vis\u00C3\u00A3o/g, 'visão')
    .replace(/poss\u00C3\u00ADvel/g, 'possível')
    .replace(/t\u00C3\u00ADtulo/g, 'título');
}

function escapeHtml(s) {
  return normalizeDisplayText(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}


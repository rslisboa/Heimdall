function isCalendarAlertEvent(e) {
  const externalId = String(e.external_id || '');
  const title = String(e.title || '');

  return (
    e.source === 'calendar' &&
    (
      externalId.startsWith('alert:') ||
      title.startsWith('Reunião em ') ||
      title.includes(' min:')
    )
  );
}

function deduplicarEventosCalendario(events) {
  const seen = new Set();
  const result = [];

  events.forEach(e => {
    if (isCalendarAlertEvent(e)) {
      return;
    }

    if (e.source !== 'calendar') {
      result.push(e);
      return;
    }

    const metadata = e.metadata || {};

    const key = [
      e.source || '',
      e.title || '',
      metadata.start || '',
      metadata.end || '',
      metadata.location || ''
    ].join('|').toLowerCase();

    if (seen.has(key)) {
      return;
    }

    seen.add(key);
    result.push(e);
  });

  return result;
}

function getCalendarEventDateKey(e) {
  const metadata = e.metadata || {};
  return toLocalDateKey(metadata.start || metadata.date || e.created_at || '');
}

function getCalendarSelectedDateTitle() {
  return formatDateTitle(selectedCalendarDate);
}

function isSameMonth(dateA, dateB) {
  return (
    dateA.getFullYear() === dateB.getFullYear() &&
    dateA.getMonth() === dateB.getMonth()
  );
}

function getCalendarMonthLabel(date) {
  return date.toLocaleDateString('pt-BR', {
    month: 'long',
    year: 'numeric'
  });
}

function countMeetingsByDay(events) {
  const counts = {};

  events
    .filter(e => e.source === 'calendar')
    .forEach(e => {
      const key = getCalendarEventDateKey(e);
      counts[key] = (counts[key] || 0) + 1;
    });

  return counts;
}

function renderCalendarPanel(events) {
  const panel = document.getElementById('calendarPanel');

  if (!panel) {
    return;
  }

  if (currentView !== 'calendar') {
    panel.style.display = 'none';
    return;
  }

  panel.style.display = 'block';

  const grid = document.getElementById('calendarGrid');
  const title = document.getElementById('calendarMonthTitle');
  const badge = document.getElementById('calendarSelectedBadge');

  if (!grid || !title || !badge) {
    return;
  }

  grid.innerHTML = '';

  title.textContent = getCalendarMonthLabel(calendarMonthCursor);
  badge.textContent = getCalendarSelectedDateTitle();

  const meetingCounts = countMeetingsByDay(events);

  const year = calendarMonthCursor.getFullYear();
  const month = calendarMonthCursor.getMonth();

  const firstDay = new Date(year, month, 1);
  const lastDay = new Date(year, month + 1, 0);

  const startOffset = (firstDay.getDay() + 6) % 7;
  const totalCells = Math.ceil((startOffset + lastDay.getDate()) / 7) * 7;

  const todayKey = toLocalDateKey(new Date().toISOString());

  for (let i = 0; i < totalCells; i++) {
    const dayNumber = i - startOffset + 1;
    const btn = document.createElement('button');
    btn.type = 'button';

    if (dayNumber < 1 || dayNumber > lastDay.getDate()) {
      btn.className = 'calendar-day empty';
      btn.disabled = true;
      grid.appendChild(btn);
      continue;
    }

    const date = new Date(year, month, dayNumber, 12, 0, 0);
    const dateKey = toLocalDateKey(date.toISOString());
    const count = meetingCounts[dateKey] || 0;

    btn.className = 'calendar-day';

    if (dateKey === selectedCalendarDate) {
      btn.classList.add('selected');
    }

    if (dateKey === todayKey) {
      btn.classList.add('today');
    }

    if (count > 0) {
      btn.classList.add('has-meeting');
    }

    btn.innerHTML = `
      <span class="calendar-day-number">${dayNumber}</span>
      <span class="calendar-day-count">${count > 0 ? `${count} reunião(ões)` : ''}</span>
    `;

    btn.addEventListener('click', () => {
      selectedCalendarDate = dateKey;
      calendarMonthCursor = new Date(`${selectedCalendarDate}T12:00:00`);

      loadEvents();
      loadActivity();
    });

    grid.appendChild(btn);
  }
}

function getTaskStatusLabel(status) {

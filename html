function updateCoderAgentCard(agent = {}, timestamp = null) {
  const map = {
    python: 'coderPython',
    javascript: 'coderJavaScript',
    sql: 'coderSql',
    html_css: 'coderHtmlCss',
    r: 'coderR'
  };
  const key = String(agent.name || agent.language || '').toLowerCase().replace(/[^a-z0-9]+/g, '_');
  const targetId = map[key] || map[String(agent.language || '').toLowerCase()];
  const el = targetId ? document.getElementById(targetId) : null;

  if (el) {
    let content = agent.finding || agent.status || agent.summary || 'Monitorando sem achados criticos.';
    if (timestamp) {
      const timeStr = new Date(timestamp).toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
      content = `[Última verificação: ${timeStr}]\n\n${content}`;
    }
    el.textContent = content;
  }
}

async function loadCodersInventory() {
  const stream = document.getElementById('codersStream');

  if (!stream) {
    return;
  }

  stream.textContent = 'Lendo inventario do projeto Heimdall...';

  try {
    const data = await fetch('/api/coders/inventory').then(r => r.json());
    const inv = data.inventory || {};
    const parts = Object.entries(inv.languages || {})
      .map(([language, count]) => `${language}: ${count} arquivo(s)`);

    stream.textContent = `Inventario ativo.\n${parts.join('\n') || 'Nenhum arquivo mapeado.'}\n\nOs agentes estao prontos para auditoria sob demanda.`;
  } catch (error) {
    console.warn('Falha ao carregar Coders:', error);
    stream.textContent = 'Nao foi possivel carregar o inventario do projeto.';
  }
}

async function runCodersAnalysis() {
  const stream = document.getElementById('codersStream');
  const codersPromptEl = document.getElementById('codersPrompt');
  const codersFilePathEl = document.getElementById('codersFilePath');
  const codersLanguageEl = document.getElementById('codersLanguage');
  const prompt = codersPromptEl ? codersPromptEl.value || '' : '';
  const filePath = codersFilePathEl ? codersFilePathEl.value || '' : '';
  const language = codersLanguageEl ? codersLanguageEl.value || 'auto' : 'auto';
  const btn = document.getElementById('codersAnalyzeBtn');

  if (!stream) {
    return;
  }

  if (btn) {
    btn.disabled = true;
    btn.textContent = 'Analisando...';
  }

  stream.textContent = 'Coders Conclave em analise com a Gemma local...';

  try {
    const data = await fetch('/api/coders/analyze', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ prompt, file_path: filePath, language })
    }).then(r => r.json());

    const agents = Array.isArray(data.agents) ? data.agents : [];
    agents.forEach(a => updateCoderAgentCard(a, data.checked_at || new Date().toISOString()));

    stream.textContent = [
      data.summary || 'Analise concluida.',
      '',
      ...(Array.isArray(data.risks) ? data.risks.map(risk => `Risco: ${risk}`) : []),
      ...(Array.isArray(data.recommendations) ? data.recommendations.map(item => `Recomendacao: ${item}`) : [])
    ].filter(Boolean).join('\n');
  } catch (error) {
    console.error('Erro no Coders Conclave:', error);
    stream.textContent = `Falha ao analisar codigo: ${error.message}`;
  } finally {
    if (btn) {
      btn.disabled = false;
      btn.textContent = 'Analisar';
    }
  }
}

function setupCoders() {
  const btn = document.getElementById('codersAnalyzeBtn');

  if (btn) {
    btn.addEventListener('click', runCodersAnalysis);
  }
}

function setupTasks() {
  const titleInput = document.getElementById('taskTitleInput');
  const deadlineInput = document.getElementById('taskDeadlineInput');
  const fileInput = document.getElementById('taskFileInput');
  const createBtn = document.getElementById('taskCreateBtn');

  if (!titleInput || !createBtn) return;

  createBtn.addEventListener('click', async () => {
    const prompt = titleInput.value.trim();
    const deadline = deadlineInput ? deadlineInput.value.trim() : '';

    if (!prompt) {
      alert('Informe a descrição do lembrete.');
      titleInput.focus();
      return;
    }

    createBtn.disabled = true;
    createBtn.textContent = 'Guardando...';

    try {
      requestBrowserNotificationPermission();

      const formData = new FormData();
      formData.append('prompt', prompt);
      formData.append('title', prompt);
      formData.append('deadline', deadline);

      if (fileInput && fileInput.files && fileInput.files.length) {
        Array.from(fileInput.files).forEach(file => {
          formData.append('files', file);
        });
      }

      const response = await fetch('/api/tasks/agent', {
        method: 'POST',
        body: formData,
      });

      const rawText = await response.text();

      let data = {};

      try {
        data = JSON.parse(rawText);
      } catch (error) {
        throw new Error(
          rawText.includes('Internal Server Error')
            ? 'O lembrete foi enviado, mas o backend quebrou depois de salvar. Verifique o app.py, principalmente db.log com task_agent.'
            : `Resposta inválida do servidor: ${rawText}`
        );
      }

      if (!response.ok || !data.ok) {
        throw new Error(data.message || data.erro || `Erro HTTP ${response.status}`);
      }

      titleInput.value = '';

      if (deadlineInput) {
        deadlineInput.value = '';
      }

      if (fileInput) {
        fileInput.value = '';
      }

      await renderTaskPanel();
      await loadEvents();
      await loadKpis();
      await loadActivity();

    } catch (error) {
      console.error('Erro ao criar lembrete:', error);
      alert(`Não foi possível criar o lembrete: ${error.message}`);
    } finally {
      createBtn.disabled = false;
      createBtn.textContent = 'Guardar lembrete';
    }
  });
}

